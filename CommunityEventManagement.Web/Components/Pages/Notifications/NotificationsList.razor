@page "/notifications"
@using CommunityEventManagement.Domain.Entities
@using CommunityEventManagement.Domain.Interfaces.Services
@using CommunityEventManagement.Web.Services
@inject INotificationService NotificationService
@inject IEventService EventService
@inject AuthStateService AuthState
@inject NavigationManager Navigation
@implements IDisposable

<PageTitle>Notifications Console — Community Events</PageTitle>

<div class="page-header-console bg-white border-bottom py-4 px-5 d-flex justify-content-between align-items-center shadow-sm mb-5">
    <div>
        <h1 class="h3 fw-bold text-dark mb-1">Notifications Console</h1>
        <p class="text-muted small mb-0">Real-time alerts for new events, schedule changes, and registration confirmations.</p>
    </div>
    @if (AuthState.IsAuthenticated && _notifications.Any(n => !n.IsRead))
    {
        <button class="btn btn-outline-secondary small py-2 px-4 fw-bold shadow-sm" @onclick="MarkAllReadAsync">
            <i class="bi bi-check-all me-2"></i> Mark all as read
        </button>
    }
</div>

<div class="container pb-5">
    @if (!AuthState.IsAuthenticated)
    {
        <div class="modern-container card border-0 shadow-sm rounded-4 p-5 text-center bg-white">
            <i class="bi bi-shield-lock display-4 text-muted mb-3 d-block"></i>
            <h4 class="fw-bold text-dark mb-1">Authentication Required</h4>
            <p class="text-muted mb-4">Please sign in to view your personalized activity notifications.</p>
            <a href="/login?returnUrl=/notifications" class="btn btn-primary fw-bold px-4 py-2 shadow-sm">Sign in</a>
        </div>
    }
    else if (_isLoading)
    {
        <div class="d-flex justify-content-center my-5">
            <div class="spinner-border text-primary" role="status"></div>
        </div>
    }
    else if (!_notifications.Any())
    {
        <div class="modern-container card border-0 shadow-sm rounded-4 p-5 text-center bg-white">
            <i class="bi bi-bell-slash display-4 text-muted mb-3 d-block"></i>
            <h4 class="fw-bold text-dark mb-1">No notifications</h4>
            <p class="text-muted mb-0">You are completely up to date with all community schedules.</p>
        </div>
    }
    else
    {
        <div class="modern-container card border-0 shadow-sm rounded-4 bg-white overflow-hidden mb-5">
            <div class="list-group list-group-flush">
                @foreach (var notif in _notifications)
                {
                    <div class="list-group-item p-4 @(notif.IsRead ? "bg-white" : "bg-primary-subtle border-start border-primary border-4")">
                        <div class="d-flex align-items-start justify-content-between">
                            <div class="d-flex align-items-start gap-3">
                                <div class="p-2 bg-light border rounded-circle d-flex align-items-center justify-content-center mt-1 shadow-sm" style="width: 42px; height: 42px;">
                                    <i class="bi @notif.GetIconClass() fs-5"></i>
                                </div>
                                <div>
                                    <div class="d-flex align-items-center gap-2 mb-1">
                                        <h5 class="fw-bold text-dark mb-0 fs-6">@notif.Title</h5>
                                        @if (!notif.IsRead)
                                        {
                                            <span class="badge bg-primary px-2 py-0 rounded-pill small">New</span>
                                        }
                                    </div>
                                    <p class="text-muted small mb-2 fw-medium">@notif.Message</p>
                                    <span class="text-muted small fw-semibold"><i class="bi bi-clock me-1 opacity-75"></i> @notif.GetTimeAgo()</span>
                                </div>
                            </div>
                            <div class="d-flex gap-2">
                                @if (notif.EventId.HasValue)
                                {
                                    <a href="/events/@notif.EventId.Value" class="btn btn-sm btn-outline-secondary py-1 px-3 fw-bold shadow-sm" @onclick="() => MarkReadAsync(notif.Id)">
                                        View Event
                                    </a>
                                }
                                @if (!notif.IsRead)
                                {
                                    <button class="btn btn-sm btn-outline-secondary py-1 px-3 fw-bold shadow-sm" @onclick="() => MarkReadAsync(notif.Id)">
                                        Dismiss
                                    </button>
                                }
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    }
</div>

@code {
    private List<Notification> _notifications = new();
    private bool _isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        AuthState.OnAuthStateChanged += AuthChanged;
        NotificationService.OnNotificationUpdated += NotificationsChanged;
        await LoadNotificationsAsync();
    }

    private async void AuthChanged() => await InvokeAsync(async () => { await LoadNotificationsAsync(); StateHasChanged(); });
    private async void NotificationsChanged() => await InvokeAsync(async () => { await LoadNotificationsAsync(); StateHasChanged(); });

    private async Task LoadNotificationsAsync()
    {
        if (AuthState.IsAuthenticated && AuthState.UserId.HasValue)
        {
            _isLoading = true;
            
            // Trigger automatic check for approaching events
            var upcoming = await EventService.GetUpcomingEventsAsync();
            await NotificationService.CheckApproachingEventsAsync(upcoming);

            var data = await NotificationService.GetNotificationsForParticipantAsync(AuthState.UserId.Value);
            _notifications = data.ToList();
            _isLoading = false;
        }
    }

    private async Task MarkReadAsync(string id)
    {
        await NotificationService.MarkAsReadAsync(id);
        await LoadNotificationsAsync();
    }

    private async Task MarkAllReadAsync()
    {
        if (AuthState.UserId.HasValue)
        {
            await NotificationService.MarkAllAsReadAsync(AuthState.UserId.Value);
            await LoadNotificationsAsync();
        }
    }

    public void Dispose()
    {
        AuthState.OnAuthStateChanged -= AuthChanged;
        NotificationService.OnNotificationUpdated -= NotificationsChanged;
    }
}