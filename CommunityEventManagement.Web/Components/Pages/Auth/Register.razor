@page "/register"
@using CommunityEventManagement.Web.Services
@using System.ComponentModel.DataAnnotations
@inject AuthStateService AuthState
@inject NavigationManager Navigation

<PageTitle>Create Account — Community Events</PageTitle>

<div class="container py-5 my-5">
    <div class="row justify-content-center">
        <div class="col-md-7 col-lg-6">
            <div class="modern-card p-5">
                <div class="text-center mb-5">
                    <i class="bi bi-layers-fill text-primary display-4 mb-3 d-block"></i>
                    <h2 class="fw-bold text-dark mb-1">Create Account</h2>
                    <p class="text-muted small mb-0">Sign up to register and participate in community events</p>
                </div>

                @if (!string.IsNullOrEmpty(_errorMessage))
                {
                    <div class="alert alert-danger mb-4 d-flex align-items-center shadow-sm" role="alert">
                        <i class="bi bi-exclamation-triangle-fill me-2 fs-5"></i>
                        <div>@_errorMessage</div>
                    </div>
                }

                <EditForm Model="@_model" OnValidSubmit="HandleRegisterAsync">
                    <DataAnnotationsValidator />

                    <div class="row mb-4">
                        <div class="col-md-6">
                            <label class="form-label">First Name</label>
                            <input @bind="_model.FirstName" class="form-control py-2" placeholder="First name" />
                            <ValidationMessage For="@(() => _model.FirstName)" class="text-danger small" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Last Name</label>
                            <input @bind="_model.LastName" class="form-control py-2" placeholder="Last name" />
                            <ValidationMessage For="@(() => _model.LastName)" class="text-danger small" />
                        </div>
                    </div>

                    <div class="mb-4">
                        <label class="form-label">Email Address <span class="text-danger">*</span></label>
                        <input type="email" @bind="_model.Email" class="form-control py-2" placeholder="you@example.com" />
                        <ValidationMessage For="@(() => _model.Email)" class="text-danger small" />
                    </div>

                    <div class="mb-4">
                        <label class="form-label">Phone Number</label>
                        <input type="tel" @bind="_model.PhoneNumber" class="form-control py-2" placeholder="07700 000000" />
                        <ValidationMessage For="@(() => _model.PhoneNumber)" class="text-danger small" />
                    </div>

                    <div class="mb-4">
                        <label class="form-label">Password <span class="text-danger">*</span></label>
                        <input type="password" @bind="_model.Password" class="form-control py-2" placeholder="At least 6 characters" />
                        <ValidationMessage For="@(() => _model.Password)" class="text-danger small" />
                    </div>

                    <div class="mb-5">
                        <label class="form-label">Confirm Password <span class="text-danger">*</span></label>
                        <input type="password" @bind="_model.ConfirmPassword" class="form-control py-2" placeholder="Re-enter password" />
                        <ValidationMessage For="@(() => _model.ConfirmPassword)" class="text-danger small" />
                    </div>

                    <button type="submit" class="btn-modern-primary w-100 py-3 mb-4" disabled="@_isSubmitting">
                        @if (_isSubmitting)
                        {
                            <span class="spinner-border spinner-border-sm me-2"></span>
                            <span>Creating account...</span>
                        }
                        else
                        {
                            <span>Create Account</span>
                        }
                    </button>
                </EditForm>

                <div class="text-center border-top pt-4">
                    <small class="text-muted">
                        Already have an account? <a href="/login" class="text-primary fw-semibold text-decoration-none">Sign in</a>
                    </small>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private RegisterFormModel _model = new();
    private string _errorMessage = string.Empty;
    private bool _isSubmitting = false;

    private async Task HandleRegisterAsync()
    {
        _errorMessage = string.Empty;
        _isSubmitting = true;

        try
        {
            var result = await AuthState.RegisterParticipantAsync(
                _model.FirstName, _model.LastName, _model.Email,
                _model.PhoneNumber, _model.Password);

            if (result.Success)
            {
                Navigation.NavigateTo("/login?registered=true", forceLoad: false);
            }
            else
            {
                _errorMessage = result.ErrorMessage;
            }
        }
        catch (Exception ex)
        {
            _errorMessage = $"An unexpected error occurred: {ex.Message}";
        }
        finally
        {
            _isSubmitting = false;
        }
    }

    private class RegisterFormModel
    {
        [Required(ErrorMessage = "First name is required")]
        [StringLength(50, MinimumLength = 2)]
        public string FirstName { get; set; } = string.Empty;

        [Required(ErrorMessage = "Last name is required")]
        [StringLength(50, MinimumLength = 2)]
        public string LastName { get; set; } = string.Empty;

        [Required(ErrorMessage = "Email is required")]
        [EmailAddress(ErrorMessage = "Enter a valid email address")]
        [RegularExpression(@"^[^@\s]+@[^@\s]+\.[^@\s]+$", ErrorMessage = "Invalid email format.")]
        public string Email { get; set; } = string.Empty;

        [Phone(ErrorMessage = "Enter a valid phone number")]
        [RegularExpression(@"^\+?[0-9]{5,15}$", ErrorMessage = "Phone number must contain 5 to 15 digits (e.g., +447700900077 or 07700900077).")]
        public string? PhoneNumber { get; set; }

        [Required(ErrorMessage = "Password is required")]
        [StringLength(100, MinimumLength = 6, ErrorMessage = "Password must be at least 6 characters")]
        [DataType(DataType.Password)]
        public string Password { get; set; } = string.Empty;

        [Required(ErrorMessage = "Please confirm your password")]
        [Compare(nameof(Password), ErrorMessage = "Passwords do not match")]
        [DataType(DataType.Password)]
        public string ConfirmPassword { get; set; } = string.Empty;
    }
}