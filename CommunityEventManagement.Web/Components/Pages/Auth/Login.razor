@page "/login"
@using CommunityEventManagement.Web.Services
@inject AuthStateService AuthState
@inject NavigationManager Navigation

<PageTitle>Sign In — Community Events</PageTitle>

<div class="container py-5 my-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">
            <div class="modern-card p-5">
                <div class="text-center mb-5">
                    <i class="bi bi-layers-fill text-primary display-4 mb-3 d-block"></i>
                    <h2 class="fw-bold text-dark mb-1">Sign In</h2>
                    <p class="text-muted small mb-0">Community Event Management Portal</p>
                </div>

                @if (!string.IsNullOrEmpty(_successMessage))
                {
                    <div class="alert alert-success mb-4" role="alert">
                        @_successMessage
                    </div>
                }

                @if (!string.IsNullOrEmpty(_errorMessage))
                {
                    <div class="alert alert-danger mb-4" role="alert">
                        @_errorMessage
                    </div>
                }

                <EditForm Model="@_model" OnValidSubmit="HandleLoginAsync">
                    <DataAnnotationsValidator />

                    <div class="mb-4">
                        <label class="form-label">Email Address</label>
                        <input type="email" @bind="_model.Email" class="form-control py-2" placeholder="you@example.com" />
                        <ValidationMessage For="@(() => _model.Email)" class="text-danger small" />
                    </div>

                    <div class="mb-5">
                        <label class="form-label">Password</label>
                        <input type="password" @bind="_model.Password" class="form-control py-2" placeholder="Enter your password" />
                        <ValidationMessage For="@(() => _model.Password)" class="text-danger small" />
                    </div>

                    <button type="submit" class="btn-modern-primary w-100 py-3 mb-4" disabled="@_isProcessing">
                        @if (_isProcessing)
                        {
                            <span class="spinner-border spinner-border-sm me-2"></span>
                            <span>Signing in...</span>
                        }
                        else
                        {
                            <span>Sign In</span>
                        }
                    </button>
                </EditForm>

                <div class="text-center border-top pt-4">
                    <small class="text-muted">
                        Don't have an account? <a href="/register" class="text-primary fw-semibold text-decoration-none">Create one</a>
                    </small>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private LoginViewModel _model = new();
    private string _errorMessage = string.Empty;
    private string _successMessage = string.Empty;
    private bool _isProcessing = false;

    protected override void OnInitialized()
    {
        var uri = Navigation.Uri;
        if (uri.Contains("registered=true"))
        {
            _successMessage = "Account created successfully. Please sign in.";
        }

        if (AuthState.IsAuthenticated)
        {
            Navigation.NavigateTo("/events");
        }
    }

    private async Task HandleLoginAsync()
    {
        _errorMessage = string.Empty;
        _successMessage = string.Empty;
        _isProcessing = true;

        try
        {
            var success = await AuthState.LoginAsync(_model.Email, _model.Password);

            if (success)
            {
                Navigation.NavigateTo("/events", forceLoad: false);
            }
            else
            {
                _errorMessage = "Invalid email or password.";
                _model.Password = string.Empty;
            }
        }
        catch (CommunityEventManagement.Domain.Exceptions.AuthenticationException ex)
        {
            _errorMessage = ex.Message;
        }
        catch (Exception ex)
        {
            _errorMessage = $"Sign-in error: {ex.Message}";
        }
        finally
        {
            _isProcessing = false;
        }
    }
}