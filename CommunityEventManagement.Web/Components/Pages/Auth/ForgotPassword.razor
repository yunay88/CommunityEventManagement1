@page "/forgot-password"
@using CommunityEventManagement.Domain.Interfaces.Services
@using System.ComponentModel.DataAnnotations
@inject IParticipantService ParticipantService
@inject NavigationManager Navigation

<PageTitle>Forgot Password — Community Events</PageTitle>

<div class="container py-5 my-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">
            <div class="modern-card p-5">
                <div class="text-center mb-5">
                    <i class="bi bi-key-fill text-primary display-4 mb-3 d-block"></i>
                    <h2 class="fw-bold text-dark mb-1">Account Recovery</h2>
                    <p class="text-muted small mb-0">Enter your registered email address to receive a secure password reset link.</p>
                </div>

                @if (!string.IsNullOrEmpty(_errorMessage))
                {
                    <div class="alert alert-danger mb-4 d-flex align-items-center shadow-sm" role="alert">
                        <i class="bi bi-exclamation-triangle-fill me-2 fs-5"></i>
                        <div>@_errorMessage</div>
                    </div>
                }

                @if (_isSubmitted)
                {
                    <div class="modern-container card border-0 shadow-sm rounded-4 p-4 bg-slate-50 text-center mb-4">
                        <i class="bi bi-envelope-check text-success display-4 mb-3 d-block"></i>
                        <h5 class="fw-bold text-dark mb-2">Reset Link Dispatched</h5>
                        <p class="text-muted small mb-4">If an account matches <strong>@_model.Email</strong>, a password reset email has been sent with instructions.</p>
                        
                        <!-- ENTERPRISE SIMULATION QUICK-LINK FOR PANOPTO VIDEO -->
                        <div class="pt-3 border-top">
                            <span class="badge bg-warning text-dark px-3 py-1 rounded-pill mb-2 shadow-sm fw-bold">Simulation Console Link</span>
                            <a href="/reset-password?email=@Uri.EscapeDataString(_model.Email)" class="btn btn-sm btn-outline-primary fw-bold w-100 py-2 shadow-sm">
                                [Click here to execute reset simulation]
                            </a>
                        </div>
                    </div>
                    <a href="/login" class="btn-modern-secondary w-100 py-3 text-center">Return to Sign In</a>
                }
                else
                {
                    <EditForm Model="@_model" OnValidSubmit="HandleSubmitAsync">
                        <DataAnnotationsValidator />

                        <div class="mb-5">
                            <label class="form-label">Registered Email Address</label>
                            <input type="email" @bind="_model.Email" class="form-control py-2" placeholder="you@example.com" />
                            <ValidationMessage For="@(() => _model.Email)" class="text-danger small" />
                        </div>

                        <button type="submit" class="btn-modern-primary w-100 py-3 mb-4" disabled="@_isSubmitting">
                            @if (_isSubmitting)
                            {
                                <span class="spinner-border spinner-border-sm me-2"></span>
                                <span>Generating link...</span>
                            }
                            else
                            {
                                <span>Send Reset Link</span>
                            }
                        </button>
                    </EditForm>

                    <div class="text-center border-top pt-4">
                        <small class="text-muted">
                            Remember your password? <a href="/login" class="text-primary fw-semibold text-decoration-none">Sign in</a>
                        </small>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@code {
    private ForgotPasswordModel _model = new();
    private bool _isSubmitting = false;
    private bool _isSubmitted = false;
    private string _errorMessage = string.Empty;

    private async Task HandleSubmitAsync()
    {
        _isSubmitting = true;
        _errorMessage = string.Empty;
        try
        {
            var exists = await ParticipantService.EmailExistsAsync(_model.Email);
            if (!exists)
            {
                _errorMessage = "No account found with this email address.";
                return;
            }
            _isSubmitted = true;
        }
        catch (Exception ex)
        {
            _errorMessage = $"Recovery error: {ex.Message}";
        }
        finally
        {
            _isSubmitting = false;
        }
    }

    private class ForgotPasswordModel
    {
        [Required(ErrorMessage = "Email address is required")]
        [EmailAddress(ErrorMessage = "Enter a valid email address")]
        public string Email { get; set; } = string.Empty;
    }
}