@* FILE: CommunityEventManagement.Web/Components/Pages/Activities/ActivityCreate.razor *@
@* REPLACE ENTIRE FILE – adds Auth gating *@
@page "/activities/create"
@page "/activities/edit/{Id:int}"
@using CommunityEventManagement.Web.Services
@inject IActivityService ActivityService
@inject AuthStateService AuthState
@inject NavigationManager Navigation

<PageTitle>@(Id == 0 ? "Add Activity" : "Edit Activity")</PageTitle>

@if (!AuthState.IsAdmin)
{
    <div class="container py-5">
        <div class="alert alert-danger">
            <h5><i class="bi bi-shield-exclamation"></i> Admin Access Required</h5>
            <p>Only administrators can manage activities.</p>
            <a href="/login" class="btn btn-primary btn-sm">Login</a>
            <a href="/activities" class="btn btn-outline-secondary btn-sm">Back</a>
        </div>
    </div>
}
else
{
<div class="page-header">
    <div class="container">
        <h1 class="fw-bold mb-0">
            <i class="bi bi-lightning"></i>
            @(Id == 0 ? "Add Activity" : "Edit Activity")
        </h1>
        <small class="text-light opacity-75">Admin: @AuthState.CurrentUser.FullName</small>
    </div>
</div>

<div class="container pb-5">
    <div class="row justify-content-center">
        <div class="col-lg-6">
            <div class="card shadow-sm">
                <div class="card-body p-4">
                    <AlertMessage Message="@_error" Type="danger"
                                  OnDismissed="@(()=>_error=string.Empty)" />

                    <EditForm Model="_model" OnValidSubmit="HandleSubmit">
                        <DataAnnotationsValidator />
                        <ValidationSummary class="alert alert-warning" />

                        <div class="mb-3">
                            <label class="form-label fw-semibold">Name *</label>
                            <InputText @bind-Value="_model.Name"
                                       class="form-control" />
                            <ValidationMessage For="@(()=>_model.Name)"
                                               class="text-danger small" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-semibold">
                                Description
                            </label>
                            <InputTextArea @bind-Value="_model.Description"
                                           class="form-control" rows="2" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-semibold">Type *</label>
                            <InputSelect @bind-Value="_model.Type"
                                         class="form-select">
                                @foreach (var t in Enum.GetValues<ActivityType>())
                                {
                                    <option value="@t">@t</option>
                                }
                            </InputSelect>
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-semibold">
                                Duration (minutes) *
                            </label>
                            <InputNumber @bind-Value="_model.DurationMinutes"
                                         class="form-control" />
                            <ValidationMessage For="@(()=>_model.DurationMinutes)"
                                               class="text-danger small" />
                        </div>

                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-primary"
                                    disabled="@_submitting">
                                <i class="bi bi-check-circle"></i>
                                @(Id == 0 ? "Add Activity" : "Save Changes")
                            </button>
                            <a href="/activities"
                               class="btn btn-outline-secondary">
                                <i class="bi bi-x"></i> Cancel
                            </a>
                        </div>
                    </EditForm>
                </div>
            </div>
        </div>
    </div>
</div>
}

@code {
    [Parameter] public int Id { get; set; }
    private CreateActivityModel _model = new();
    private bool _submitting;
    private string _error = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        if (!AuthState.IsAdmin)
        {
            Navigation.NavigateTo($"/login?returnUrl=/activities/{(Id==0?"create":"edit/"+Id)}");
            return;
        }
        if (Id != 0)
        {
            var a = await ActivityService.GetActivityByIdAsync(Id);
            if (a != null) _model = CreateActivityModel.FromEntity(a);
        }
    }

    private async Task HandleSubmit()
    {
        if (!AuthState.IsAdmin) { _error = "Admin access required."; return; }
        try
        {
            _submitting = true;
            if (Id == 0)
                await ActivityService.CreateActivityAsync(
                    _model.Name, _model.Description,
                    _model.Type, _model.DurationMinutes);
            else
                await ActivityService.UpdateActivityAsync(
                    Id, _model.Name, _model.Description,
                    _model.Type, _model.DurationMinutes);

            Navigation.NavigateTo("/activities");
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { _submitting = false; }
    }
}
