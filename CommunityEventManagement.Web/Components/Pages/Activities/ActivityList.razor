@page "/activities"
@using CommunityEventManagement.Web.Services
@using CommunityEventManagement.Web.ViewModels
@inject IActivityService ActivityService
@inject AuthStateService AuthState
@implements IDisposable

<PageTitle>Activities Console — Community Events</PageTitle>

<div class="page-header-console bg-white border-bottom py-4 px-5 d-flex justify-content-between align-items-center shadow-sm mb-5">
    <div>
        <h1 class="h3 fw-bold text-dark mb-1">Activities Console</h1>
        <p class="text-muted small mb-0">Modular event sub-items, timing allocations, and interactive community workflows.</p>
    </div>
    @if (AuthState.IsAdmin)
    {
        <a href="/activities/create" class="btn btn-primary fw-bold px-4 py-2 shadow-sm">
            <i class="bi bi-plus-lg me-2"></i> Add Activity
        </a>
    }
</div>

<div class="container pb-5">
    <AlertMessage Message="@_success" Type="success" OnDismissed="@(() => _success = string.Empty)" />
    <AlertMessage Message="@_error" Type="danger" OnDismissed="@(() => _error = string.Empty)" />

    @if (!AuthState.IsAdmin)
    {
        <div class="alert alert-info mb-4 shadow-sm d-flex align-items-center">
            <i class="bi bi-eye me-2 fs-5"></i>
            <div>Read-only mode. <a href="/login" class="fw-bold text-decoration-none">Sign in as Administrator</a> to manage activities.</div>
        </div>
    }

    <!-- Modern Live Search Bar Console -->
    <div class="modern-container card border-0 shadow-sm rounded-4 p-4 mb-5 bg-white">
        <div class="d-flex align-items-center mb-1">
            <i class="bi bi-search text-primary me-3 fs-5"></i>
            <div class="flex-grow-1">
                <input class="form-control border-0 bg-slate-50 py-2 shadow-none fw-medium text-dark" placeholder="Type activity name..."
                       @bind="_searchTerm" @bind:event="oninput" />
            </div>
            @if (!string.IsNullOrEmpty(_searchTerm))
            {
                <button class="btn btn-sm btn-outline-secondary py-1 px-3 ms-3 fw-bold shadow-sm" @onclick="() => _searchTerm = string.Empty">Clear</button>
            }
        </div>
    </div>

    <LoadingSpinner IsLoading="@_loading" />

    @if (!_loading)
    {
        <div class="modern-container card border-0 shadow-sm rounded-4 bg-white overflow-hidden mb-5">
            <div class="p-4 border-bottom bg-slate-50 d-flex justify-content-between align-items-center">
                <h2 class="h5 fw-bold text-dark mb-0 d-flex align-items-center">
                    <i class="bi bi-lightning-charge text-warning me-2"></i> Activity Directory
                </h2>
                <span class="badge bg-secondary px-3 py-1 rounded-pill shadow-sm">@_filteredActivities.Count active item(s)</span>
            </div>

            @if (!_filteredActivities.Any())
            {
                <div class="p-5 text-center text-muted">
                    <i class="bi bi-lightning-slash display-4 text-muted mb-3 d-block"></i>
                    <h5 class="fw-bold text-dark mb-1">No matching activities found</h5>
                    <p class="text-muted mb-0">No event activity items match your active search filter.</p>
                </div>
            }
            else
            {
                <table class="table table-hover mb-0 align-middle">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-4">Activity Name</th>
                            <th>Category Type</th>
                            <th>Description</th>
                            <th>Duration</th>
                            @if (AuthState.IsAdmin)
                            {
                                <th class="pe-4 text-end">Action</th>
                            }
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var act in _filteredActivities)
                        {
                            <tr>
                                <td class="ps-4 fw-bold text-dark">@act.Name</td>
                                <td>
                                    <span class="badge bg-secondary px-3 py-1 rounded-pill shadow-sm">@act.TypeName</span>
                                </td>
                                <td class="text-secondary fw-medium">@act.Description</td>
                                <td class="text-muted fw-bold"><i class="bi bi-clock me-1 opacity-75"></i> @act.DurationFormatted</td>
                                @if (AuthState.IsAdmin)
                                {
                                    <td class="pe-4 text-end">
                                        <button class="btn btn-sm btn-outline-danger py-1 px-3 fw-bold shadow-sm"
                                                @onclick="() => ShowDelete(act.Id, act.Name)">
                                            Delete
                                        </button>
                                    </td>
                                }
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    }
</div>

<ConfirmDialog IsVisible="@_showDelete"
               Title="Delete Activity"
               Message="@($"Delete '{_deleteName}'?")"
               OnConfirm="DoDelete"
               OnCancel="@(() => _showDelete = false)" />

@code {
    private List<ActivityViewModel> _activities = new();
    private bool _loading = true;
    private string _searchTerm = string.Empty;
    private bool _showDelete;
    private int _deleteId;
    private string _deleteName = string.Empty;
    private string _success = string.Empty;
    private string _error = string.Empty;

    private List<ActivityViewModel> _filteredActivities => string.IsNullOrWhiteSpace(_searchTerm)
        ? _activities
        : _activities.Where(a => 
            a.Name.Contains(_searchTerm, StringComparison.OrdinalIgnoreCase) || 
            (a.Description != null && a.Description.Contains(_searchTerm, StringComparison.OrdinalIgnoreCase))
          ).ToList();

    protected override async Task OnInitializedAsync()
    {
        AuthState.OnAuthStateChanged += AuthChanged;
        await Load();
    }
    private async void AuthChanged() => await InvokeAsync(StateHasChanged);

    private async Task Load()
    {
        try
        {
            _loading = true;
            var all = await ActivityService.GetAllActivitiesAsync();
            _activities = all.Select(ActivityViewModel.FromEntity).ToList();
        }
        finally { _loading = false; }
    }

    private void ShowDelete(int id, string name)
    {
        if (!AuthState.IsAdmin) { _error = "Admin access required."; return; }
        _deleteId = id; _deleteName = name; _showDelete = true;
    }

    private async Task DoDelete()
    {
        if (!AuthState.IsAdmin) { _error = "Admin access required."; return; }
        try
        {
            _showDelete = false;
            await ActivityService.DeleteActivityAsync(_deleteId);
            _success = $"Activity '{_deleteName}' deleted.";
            await Load();
        }
        catch (Exception ex) { _error = ex.Message; }
    }

    public void Dispose() => AuthState.OnAuthStateChanged -= AuthChanged;
}