@page "/"
@using CommunityEventManagement.Infrastructure.Patterns.Facade
@using CommunityEventManagement.Domain.Interfaces.Services
@using CommunityEventManagement.Web.ViewModels
@using CommunityEventManagement.Web.Services
@inject EventManagementFacade Facade
@inject IEventService EventService
@inject AuthStateService AuthState
@implements IDisposable

<PageTitle>Overview — Community Events</PageTitle>

@if (!AuthState.IsAuthenticated)
{
    <!-- Impressive Modern Landing Page Hero -->
    <div class="hero-section">
        <div class="container">
            <div class="badge bg-light text-dark border py-2 px-4 rounded-pill mb-4 shadow-sm fs-6 fw-semibold">
                <i class="bi bi-stars text-primary me-2"></i> Modern Enterprise Event Platform
            </div>
            <h1 class="hero-title">Elevate your community event experiences.</h1>
            <p class="hero-subtitle">
                A state-of-the-art management console designed for seamless activity scheduling, venue resource allocation, and participant registration tracking.
            </p>
            <div class="d-flex justify-content-center gap-3">
                <a href="/events" class="btn btn-primary btn-lg py-3 px-5 fw-bold shadow-sm d-inline-flex align-items-center">
                    Explore Events <i class="bi bi-arrow-right ms-2"></i>
                </a>
                <a href="/register" class="btn btn-outline-secondary btn-lg py-3 px-5 fw-bold shadow-sm">
                    Create Account
                </a>
            </div>
        </div>
    </div>
}
else
{
    <!-- Authenticated Dashboard Header -->
    <div class="page-header-console bg-white border-bottom py-4 px-5 d-flex justify-content-between align-items-center shadow-sm">
        <div>
            <h1 class="h3 fw-bold text-dark mb-1">System Dashboard</h1>
            <p class="text-muted small mb-0">Overview of active community schedules and platform metrics.</p>
        </div>
        @if (AuthState.IsAdmin)
        {
            <a href="/events/create" class="btn btn-primary fw-bold shadow-sm px-4 py-2">
                <i class="bi bi-plus-lg me-2"></i> Create Event
            </a>
        }
    </div>
}

<div class="container py-5">
    <LoadingSpinner IsLoading="@_isLoading" Message="Loading platform metrics..." />

    @if (!_isLoading && _summary != null)
    {
        <!-- Modern Metric Cards -->
        <div class="row g-4 mb-5">
            <div class="col-sm-6 col-lg-3">
                <div class="modern-container card border-0 shadow-sm rounded-4 p-4 bg-white">
                    <div class="d-flex align-items-center justify-content-between mb-3">
                        <span class="text-muted small fw-bold text-uppercase">Events</span>
                        <i class="bi bi-calendar-event text-primary fs-5"></i>
                    </div>
                    <div class="display-5 fw-bold text-dark mb-1">@_summary.TotalUpcomingEvents</div>
                    <div class="text-muted small">Upcoming community events</div>
                </div>
            </div>
            <div class="col-sm-6 col-lg-3">
                <div class="modern-container card border-0 shadow-sm rounded-4 p-4 bg-white">
                    <div class="d-flex align-items-center justify-content-between mb-3">
                        <span class="text-muted small fw-bold text-uppercase">Participants</span>
                        <i class="bi bi-people text-success fs-5"></i>
                    </div>
                    <div class="display-5 fw-bold text-dark mb-1">@_summary.TotalParticipants</div>
                    <div class="text-muted small">Active registered accounts</div>
                </div>
            </div>
            <div class="col-sm-6 col-lg-3">
                <div class="modern-container card border-0 shadow-sm rounded-4 p-4 bg-white">
                    <div class="d-flex align-items-center justify-content-between mb-3">
                        <span class="text-muted small fw-bold text-uppercase">Venues</span>
                        <i class="bi bi-geo-alt text-warning fs-5"></i>
                    </div>
                    <div class="display-5 fw-bold text-dark mb-1">@_summary.TotalVenues</div>
                    <div class="text-muted small">Partnered event locations</div>
                </div>
            </div>
            <div class="col-sm-6 col-lg-3">
                <div class="modern-container card border-0 shadow-sm rounded-4 p-4 bg-white">
                    <div class="d-flex align-items-center justify-content-between mb-3">
                        <span class="text-muted small fw-bold text-uppercase">Registrations</span>
                        <i class="bi bi-card-checklist text-info fs-5"></i>
                    </div>
                    <div class="display-5 fw-bold text-dark mb-1">@_summary.TotalRegistrations</div>
                    <div class="text-muted small">Total event reservations</div>
                </div>
            </div>
        </div>

        <!-- Upcoming Events Grid -->
        <div class="row">
            <div class="col-12">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h2 class="h5 fw-bold mb-0 text-dark d-flex align-items-center">
                        <i class="bi bi-clock-history text-primary me-2"></i> Upcoming Events
                    </h2>
                    <a href="/events" class="btn btn-outline-secondary small py-2 px-4 fw-bold shadow-sm">
                        View all events
                    </a>
                </div>

                @if (!_summary.RecentEvents.Any())
                {
                    <div class="modern-container card border-0 shadow-sm rounded-4 p-5 text-center bg-white">
                        <i class="bi bi-calendar-x display-4 text-muted mb-3 d-block"></i>
                        <h4 class="fw-bold text-dark mb-1">No upcoming events</h4>
                        <p class="text-muted mb-4">There are currently no upcoming community events scheduled.</p>
                        @if (AuthState.IsAdmin)
                        {
                            <a href="/events/create" class="btn btn-primary fw-bold px-4 py-2 shadow-sm">Create new event</a>
                        }
                    </div>
                }
                else
                {
                    <div class="row g-4">
                        @foreach (var evt in _summary.RecentEvents)
                        {
                            var vm = EventViewModel.FromEntity(evt);
                            <div class="col-md-6 col-lg-4">
                                <div class="modern-card card border-0 shadow-sm rounded-4 h-100 p-4 bg-white d-flex flex-column">
                                    <div class="d-flex justify-content-between align-items-center mb-3">
                                        <span class="badge bg-primary px-3 py-2 rounded-pill shadow-sm">@vm.StatusBadge</span>
                                        <span class="text-muted small fw-semibold d-flex align-items-center">
                                            <i class="bi bi-stopwatch me-1 opacity-75"></i> @vm.DurationFormatted
                                        </span>
                                    </div>
                                    <h3 class="h5 fw-bold text-dark mb-2">@vm.Name</h3>
                                    <p class="text-muted small mb-4 flex-grow-1">
                                        @(vm.Description.Length > 90 ? vm.Description[..90] + "..." : vm.Description)
                                    </p>
                                    <div class="border-top pt-3 mt-auto">
                                        <div class="text-muted small mb-2 d-flex align-items-center fw-medium">
                                            <i class="bi bi-calendar3 text-primary me-2 opacity-75"></i>
                                            @vm.StartDate.ToString("ddd dd MMM yyyy, HH:mm")
                                        </div>
                                        @if (!string.IsNullOrEmpty(vm.VenueName))
                                        {
                                            <div class="text-muted small mb-4 d-flex align-items-center fw-medium">
                                                <i class="bi bi-geo-alt text-danger me-2 opacity-75"></i>
                                                @vm.VenueName
                                            </div>
                                        }
                                        <a href="/events/@vm.Id" class="btn btn-outline-secondary w-100 py-2 fw-bold shadow-sm">
                                            View details
                                        </a>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>
    }

    <AlertMessage Message="@_errorMessage" Type="danger" />
</div>

@code {
    private EventDashboardSummary? _summary;
    private bool _isLoading = true;
    private string _errorMessage = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        AuthState.OnAuthStateChanged += AuthChanged;
        await LoadAsync();
    }

    private async void AuthChanged() => await InvokeAsync(StateHasChanged);

    private async Task LoadAsync()
    {
        try
        {
            _summary = await Facade.GetDashboardSummaryAsync();
        }
        catch (Exception ex)
        {
            _errorMessage = $"Failed to load dashboard metrics: {ex.Message}";
        }
        finally
        {
            _isLoading = false;
        }
    }

    public void Dispose()
    {
        AuthState.OnAuthStateChanged -= AuthChanged;
    }
}