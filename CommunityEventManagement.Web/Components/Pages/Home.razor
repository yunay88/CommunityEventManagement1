@* FILE: CommunityEventManagement.Web/Components/Pages/Home.razor *@
@* REPLACE ENTIRE FILE *@
@page "/"
@using CommunityEventManagement.Infrastructure.Patterns.Facade
@using CommunityEventManagement.Domain.Interfaces.Services
@using CommunityEventManagement.Web.ViewModels
@using CommunityEventManagement.Web.Services
@inject EventManagementFacade Facade
@inject IEventService EventService
@inject AuthStateService AuthState
@implements IDisposable

<PageTitle>Home — Community Events</PageTitle>

<div class="page-header">
    <div class="container">
        <div class="row align-items-center">
            <div class="col">
                <h1 class="display-5 fw-bold mb-1">
                    <i class="bi bi-calendar-event-fill"></i>
                    Community Event Management
                </h1>
                <p class="lead mb-0 opacity-75">
                    Discover, create and manage community events
                </p>
                @if (AuthState.IsAuthenticated)
                {
                    <p class="mb-0 mt-2 opacity-75 small">
                        Welcome, @AuthState.CurrentUser.FullName
                        <span class="badge bg-light text-dark">@AuthState.CurrentUser.Role</span>
                    </p>
                }
            </div>
            <div class="col-auto">
                @if (AuthState.IsAdmin)
                {
                    <a href="/events/create" class="btn btn-primary btn-lg">
                        <i class="bi bi-plus-circle"></i> Create Event
                    </a>
                }
                else if (!AuthState.IsAuthenticated)
                {
                    <a href="/login" class="btn btn-light btn-lg">
                        <i class="bi bi-box-arrow-in-right"></i> Login
                    </a>
                }
            </div>
        </div>
    </div>
</div>

<div class="container pb-5">

    <LoadingSpinner IsLoading="@_isLoading" Message="Loading dashboard..." />

    @if (!_isLoading && _summary != null)
    {
        <!-- Stats Row -->
        <div class="row g-4 mb-5">
            <div class="col-sm-6 col-lg-3">
                <div class="card stat-card shadow-sm text-center p-4
                            border-start border-primary border-4">
                    <div class="display-4 fw-bold text-primary">
                        @_summary.TotalUpcomingEvents
                    </div>
                    <div class="text-muted mt-1">
                        <i class="bi bi-calendar3"></i> Upcoming Events
                    </div>
                </div>
            </div>
            <div class="col-sm-6 col-lg-3">
                <div class="card stat-card shadow-sm text-center p-4
                            border-start border-success border-4">
                    <div class="display-4 fw-bold text-success">
                        @_summary.TotalParticipants
                    </div>
                    <div class="text-muted mt-1">
                        <i class="bi bi-people"></i> Participants
                    </div>
                </div>
            </div>
            <div class="col-sm-6 col-lg-3">
                <div class="card stat-card shadow-sm text-center p-4
                            border-start border-warning border-4">
                    <div class="display-4 fw-bold text-warning">
                        @_summary.TotalVenues
                    </div>
                    <div class="text-muted mt-1">
                        <i class="bi bi-geo-alt"></i> Venues
                    </div>
                </div>
            </div>
            <div class="col-sm-6 col-lg-3">
                <div class="card stat-card shadow-sm text-center p-4
                            border-start border-info border-4">
                    <div class="display-4 fw-bold text-info">
                        @_summary.TotalRegistrations
                    </div>
                    <div class="text-muted mt-1">
                        <i class="bi bi-card-checklist"></i> Registrations
                    </div>
                </div>
            </div>
        </div>

        <!-- Upcoming Events -->
        <div class="row">
            <div class="col-12">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h3 class="fw-bold">
                        <i class="bi bi-clock text-primary"></i>
                        Upcoming Events
                    </h3>
                    <a href="/events" class="btn btn-outline-primary btn-sm">
                        View All <i class="bi bi-arrow-right"></i>
                    </a>
                </div>

                @if (!_summary.RecentEvents.Any())
                {
                    <div class="empty-state">
                        <i class="bi bi-calendar-x display-3"></i>
                        <h5 class="mt-3">No upcoming events</h5>
                        @if (AuthState.IsAdmin)
                        {
                        <a href="/events/create" class="btn btn-primary mt-2">
                            Create the first event
                        </a>
                        }
                    </div>
                }
                else
                {
                    <div class="row g-4">
                        @foreach (var evt in _summary.RecentEvents)
                        {
                            var vm = EventViewModel.FromEntity(evt);
                            <div class="col-md-6 col-lg-4">
                                <div class="card event-card h-100 shadow-sm">
                                    <div class="card-header d-flex
                                                justify-content-between
                                                align-items-center">
                                        <span class="badge bg-@vm.StatusColour">
                                            @vm.StatusBadge
                                        </span>
                                        <small class="text-muted">
                                            @vm.DurationFormatted
                                        </small>
                                    </div>
                                    <div class="card-body">
                                        <h5 class="card-title">@vm.Name</h5>
                                        <p class="card-text text-muted small">
                                            @(vm.Description.Length > 80
                                                ? vm.Description[..80] + "..."
                                                : vm.Description)
                                        </p>
                                        <ul class="list-unstyled small mb-0">
                                            <li>
                                                <i class="bi bi-calendar3
                                                          text-primary me-1"></i>
                                                @vm.StartDate.ToString(
                                                    "ddd dd MMM yyyy, HH:mm")
                                            </li>
                                            @if (!string.IsNullOrEmpty(vm.VenueName))
                                            {
                                                <li>
                                                    <i class="bi bi-geo-alt
                                                              text-danger me-1"></i>
                                                    @vm.VenueName
                                                </li>
                                            }
                                            <li>
                                                <i class="bi bi-people
                                                          text-success me-1"></i>
                                                @vm.ParticipantCount participant(s)
                                            </li>
                                        </ul>
                                    </div>
                                    <div class="card-footer bg-transparent">
                                        <a href="/events/@vm.Id"
                                           class="btn btn-outline-primary
                                                  btn-sm w-100">
                                            <i class="bi bi-eye"></i> View Details
                                        </a>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>
    }

    <AlertMessage Message="@_errorMessage" Type="danger" />
</div>

@code {
    private EventDashboardSummary? _summary;
    private bool _isLoading = true;
    private string _errorMessage = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        AuthState.OnAuthStateChanged += AuthChanged;
        await LoadAsync();
    }

    private async void AuthChanged() => await InvokeAsync(StateHasChanged);

    private async Task LoadAsync()
    {
        try
        {
            _summary = await Facade.GetDashboardSummaryAsync();
        }
        catch (Exception ex)
        {
            _errorMessage = $"Failed to load dashboard: {ex.Message}";
        }
        finally
        {
            _isLoading = false;
        }
    }

    public void Dispose()
    {
        AuthState.OnAuthStateChanged -= AuthChanged;
    }
}
