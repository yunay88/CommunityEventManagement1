@page "/participants"
@using CommunityEventManagement.Web.Services
@using CommunityEventManagement.Web.ViewModels
@inject IParticipantService ParticipantService
@inject AuthStateService AuthState
@inject NavigationManager Navigation
@implements IDisposable

<PageTitle>Participant Accounts Console — Community Events</PageTitle>

@code {
    protected override void OnInitialized()
    {
        AuthState.OnAuthStateChanged += AuthChanged;
        if (!AuthState.IsAdmin)
        {
            Navigation.NavigateTo("/access-denied", forceLoad: true);
        }
        else
        {
            _ = LoadAsync();
        }
    }
}

@if (AuthState.IsAdmin)
{
<div class="page-header-console bg-white border-bottom py-4 px-5 d-flex justify-content-between align-items-center shadow-sm mb-5">
    <div>
        <h1 class="h3 fw-bold text-dark mb-1">Participant Accounts Console</h1>
        <p class="text-muted small mb-0">System administrative portal for tracking accounts, creating members, and searching contact records.</p>
    </div>
    <a href="/participants/create" class="btn btn-primary fw-bold px-4 py-2 shadow-sm">
        <i class="bi bi-person-plus-fill me-2"></i> Add Participant
    </a>
</div>

<div class="container pb-5">
    @if (!string.IsNullOrEmpty(_successMessage))
    {
        <div class="alert alert-success mb-4 d-flex align-items-center shadow-sm">
            <i class="bi bi-check-circle-fill me-2 fs-5"></i>
            <div><strong>Success:</strong> @_successMessage</div>
        </div>
    }
    @if (!string.IsNullOrEmpty(_errorMessage))
    {
        <div class="alert alert-danger mb-4 d-flex align-items-center shadow-sm">
            <i class="bi bi-exclamation-triangle-fill me-2 fs-5"></i>
            <div><strong>Error:</strong> @_errorMessage</div>
        </div>
    }

    <!-- Modern Live Search Bar Console -->
    <div class="modern-container card border-0 shadow-sm rounded-4 p-4 mb-5 bg-white">
        <div class="d-flex align-items-center mb-1">
            <i class="bi bi-search text-primary me-3 fs-5"></i>
            <div class="flex-grow-1">
                <input class="form-control border-0 bg-slate-50 py-2 shadow-none fw-medium text-dark" placeholder="Type name, email, or phone number ..."
                       @bind="_searchTerm" @bind:event="oninput" />
            </div>
            @if (!string.IsNullOrEmpty(_searchTerm))
            {
                <button class="btn btn-sm btn-outline-secondary py-1 px-3 ms-3 fw-bold shadow-sm" @onclick="() => _searchTerm = string.Empty">Clear</button>
            }
        </div>
    </div>

    @if (_isLoading)
    {
        <div class="d-flex justify-content-center my-5">
            <div class="spinner-border text-primary" role="status"></div>
        </div>
    }
    else if (!_filteredParticipants.Any())
    {
        <div class="modern-container card border-0 shadow-sm rounded-4 p-5 text-center bg-white">
            <i class="bi bi-people display-4 text-muted mb-3 d-block"></i>
            <h4 class="fw-bold text-dark mb-1">No matching participant accounts</h4>
            <p class="text-muted mb-4">No registered participant records match your active search criteria.</p>
            <a href="/participants/create" class="btn btn-primary fw-bold px-4 py-2 shadow-sm">Create Account</a>
        </div>
    }
    else
    {
        <div class="modern-container card border-0 shadow-sm rounded-4 bg-white overflow-hidden mb-5">
            <div class="p-4 border-bottom bg-slate-50 d-flex justify-content-between align-items-center">
                <h2 class="h5 fw-bold text-dark mb-0 d-flex align-items-center">
                    <i class="bi bi-person-lines-fill text-primary me-2"></i> Participant Directory
                </h2>
                <span class="badge bg-secondary px-3 py-1 rounded-pill shadow-sm">@_filteredParticipants.Count active account(s)</span>
            </div>
            <table class="table table-hover mb-0 align-middle">
                <thead class="table-light">
                    <tr>
                        <th class="ps-4">Full Name</th>
                        <th>Email Address</th>
                        <th>Phone Number</th>
                        <th>Confirmed Bookings</th>
                        <th>Date Created</th>
                        <th class="pe-4 text-end">Action</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var p in _filteredParticipants)
                    {
                        <tr>
                            <td class="ps-4 fw-bold text-dark">
                                <a href="/participants/@p.Id" class="text-primary text-decoration-none">@p.FullName</a>
                            </td>
                            <td class="text-secondary fw-medium">@p.Email</td>
                            <td class="text-secondary fw-medium">@(string.IsNullOrEmpty(p.PhoneNumber) ? "—" : p.PhoneNumber)</td>
                            <td>
                                <span class="badge bg-primary px-3 py-1 rounded-pill shadow-sm fs-6">@p.ActiveRegistrations</span>
                            </td>
                            <td class="text-muted">@p.CreatedAt.ToString("dd MMM yyyy")</td>
                            <td class="pe-4 text-end">
                                <a href="/participants/@p.Id" class="btn btn-sm btn-outline-secondary py-1 px-3 fw-bold shadow-sm me-1">View</a>
                                <a href="/participants/edit/@p.Id" class="btn btn-sm btn-outline-secondary py-1 px-3 fw-bold shadow-sm">Edit</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>
}

@code {
    private List<ParticipantViewModel> _participants = new();
    private bool _isLoading = true;
    private string _searchTerm = string.Empty;
    private string _successMessage = string.Empty;
    private string _errorMessage = string.Empty;

    private List<ParticipantViewModel> _filteredParticipants => string.IsNullOrWhiteSpace(_searchTerm)
        ? _participants
        : _participants.Where(p => 
            p.FullName.Contains(_searchTerm, StringComparison.OrdinalIgnoreCase) ||
            p.Email.Contains(_searchTerm, StringComparison.OrdinalIgnoreCase) ||
            (p.PhoneNumber != null && p.PhoneNumber.Contains(_searchTerm, StringComparison.OrdinalIgnoreCase))
          ).ToList();

    private async void AuthChanged() => await InvokeAsync(StateHasChanged);

    private async Task LoadAsync()
    {
        try
        {
            _isLoading = true;
            var all = await ParticipantService.GetAllParticipantsAsync();
            _participants = all.Select(ParticipantViewModel.FromEntity).ToList();
        }
        catch (Exception ex)
        {
            _errorMessage = $"Failed to load participants: {ex.Message}";
        }
        finally
        {
            _isLoading = false;
            StateHasChanged();
        }
    }

    public void Dispose() => AuthState.OnAuthStateChanged -= AuthChanged;
}