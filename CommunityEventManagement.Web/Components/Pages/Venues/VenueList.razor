@* FILE: CommunityEventManagement.Web/Components/Pages/Venues/VenueList.razor *@
@* REPLACE ENTIRE FILE *@
@page "/venues"
@using CommunityEventManagement.Web.Services
@inject IVenueService VenueService
@inject AuthStateService AuthState
@implements IDisposable

<PageTitle>Venues</PageTitle>

<div class="page-header">
    <div class="container">
        <div class="row align-items-center">
            <div class="col">
                <h1 class="fw-bold mb-0">
                    <i class="bi bi-geo-alt"></i> Venues
                </h1>
            </div>
            @if (AuthState.IsAdmin)
            {
            <div class="col-auto">
                <a href="/venues/create" class="btn btn-primary">
                    <i class="bi bi-plus"></i> Add Venue
                </a>
            </div>
            }
        </div>
    </div>
</div>

<div class="container pb-5">

    <AlertMessage Message="@_success" Type="success"
                  OnDismissed="@(() => _success = string.Empty)" />
    <AlertMessage Message="@_error" Type="danger"
                  OnDismissed="@(() => _error = string.Empty)" />

    @if (!AuthState.IsAdmin)
    {
        <div class="alert alert-info">
            <i class="bi bi-eye"></i> Read-only. <a href="/login">Login as Admin</a> to manage venues.
        </div>
    }

    <LoadingSpinner IsLoading="@_loading" />

    @if (!_loading)
    {
        <div class="row g-4">
            @foreach (var venue in _venues)
            {
                <div class="col-md-6 col-lg-4">
                    <div class="card shadow-sm h-100">
                        <div class="card-body">
                            <h5 class="card-title">@venue.Name</h5>
                            <p class="text-muted small mb-2">
                                <i class="bi bi-geo-alt me-1"></i>
                                @venue.Location
                            </p>
                            <div class="d-flex justify-content-between mb-1">
                                <span class="text-muted small">Capacity</span>
                                <strong>@venue.MaxCapacity</strong>
                            </div>
                            <div class="progress mb-2" style="height:6px;">
                                <div class="progress-bar bg-@(venue.OccupancyRate > 80
                                    ? "danger" : "success")"
                                     style="width:@venue.OccupancyRate%">
                                </div>
                            </div>
                            <small class="text-muted">
                                @venue.OccupancyRate% occupied
                            </small>
                        </div>
                        @if (AuthState.IsAdmin)
                        {
                        <div class="card-footer bg-transparent">
                            <div class="d-flex gap-2">
                                <a href="/venues/edit/@venue.Id"
                                   class="btn btn-sm btn-outline-secondary flex-grow-1">
                                    <i class="bi bi-pencil"></i> Edit
                                </a>
                                <button class="btn btn-sm btn-outline-danger"
                                        @onclick="() => ShowDelete(venue.Id, venue.Name)">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </div>
                        </div>
                        }
                    </div>
                </div>
            }
        </div>
    }
</div>

<ConfirmDialog IsVisible="@_showDelete"
               Title="Delete Venue"
               Message="@($"Delete '{_deleteName}'?")"
               OnConfirm="DoDelete"
               OnCancel="@(() => _showDelete = false)" />

@code {
    private List<VenueViewModel> _venues = new();
    private bool _loading = true;
    private bool _showDelete;
    private int _deleteId;
    private string _deleteName = string.Empty;
    private string _success = string.Empty;
    private string _error = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        AuthState.OnAuthStateChanged += AuthChanged;
        await Load();
    }
    private async void AuthChanged() => await InvokeAsync(StateHasChanged);

    private async Task Load()
    {
        try
        {
            _loading = true;
            var all = await VenueService.GetAllVenuesAsync();
            _venues = all.Select(VenueViewModel.FromEntity).ToList();
        }
        finally { _loading = false; }
    }

    private void ShowDelete(int id, string name)
    {
        if (!AuthState.IsAdmin) { _error = "Admin access required."; return; }
        _deleteId = id; _deleteName = name; _showDelete = true;
    }

    private async Task DoDelete()
    {
        if (!AuthState.IsAdmin) { _error = "Admin access required."; return; }
        try
        {
            _showDelete = false;
            await VenueService.DeleteVenueAsync(_deleteId);
            _success = $"Venue '{_deleteName}' deleted.";
            await Load();
        }
        catch (Exception ex) { _error = ex.Message; }
    }

    public void Dispose() => AuthState.OnAuthStateChanged -= AuthChanged;
}
