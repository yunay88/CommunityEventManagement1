@page "/venues"
@using CommunityEventManagement.Web.Services
@inject IVenueService VenueService
@inject AuthStateService AuthState
@implements IDisposable

<PageTitle>Venues Console — Community Events</PageTitle>

<div class="page-header-console bg-white border-bottom py-4 px-5 d-flex justify-content-between align-items-center shadow-sm mb-5">
    <div>
        <h1 class="h3 fw-bold text-dark mb-1">Venues Console</h1>
        <p class="text-muted small mb-0">Partnered event locations, structural seating thresholds, and schedule hosting management.</p>
    </div>
    @if (AuthState.IsAdmin)
    {
        <a href="/venues/create" class="btn btn-primary fw-bold px-4 py-2 shadow-sm">
            <i class="bi bi-plus-lg me-2"></i> Add Venue
        </a>
    }
</div>

<div class="container pb-5">

    <AlertMessage Message="@_success" Type="success"
                  OnDismissed="@(() => _success = string.Empty)" />
    <AlertMessage Message="@_error" Type="danger"
                  OnDismissed="@(() => _error = string.Empty)" />

    @if (!AuthState.IsAdmin)
    {
        <div class="alert alert-info mb-4 shadow-sm d-flex align-items-center">
            <i class="bi bi-eye me-2 fs-5"></i>
            <div>Read-only mode. <a href="/login" class="fw-bold text-decoration-none">Sign in as Administrator</a> to manage venues.</div>
        </div>
    }

    <!-- Modern Live Search Bar Console -->
    <div class="modern-container card border-0 shadow-sm rounded-4 p-4 mb-5 bg-white">
        <div class="d-flex align-items-center mb-1">
            <i class="bi bi-search text-primary me-3 fs-5"></i>
            <div class="flex-grow-1">
                <input class="form-control border-0 bg-slate-50 py-2 shadow-none fw-medium text-dark" placeholder="Type venue name, street address, or city ..."
                       @bind="_searchTerm" @bind:event="oninput" />
            </div>
            @if (!string.IsNullOrEmpty(_searchTerm))
            {
                <button class="btn btn-sm btn-outline-secondary py-1 px-3 ms-3 fw-bold shadow-sm" @onclick="() => _searchTerm = string.Empty">Clear</button>
            }
        </div>
    </div>

    <LoadingSpinner IsLoading="@_loading" />

    @if (!_loading)
    {
        <div class="d-flex justify-content-between align-items-center mb-4">
            <span class="text-muted small fw-bold">Showing @_filteredVenues.Count active venue(s)</span>
        </div>

        @if (!_filteredVenues.Any())
        {
            <div class="modern-container card border-0 shadow-sm rounded-4 p-5 text-center bg-white">
                <i class="bi bi-geo-alt-slash display-4 text-muted mb-3 d-block"></i>
                <h4 class="fw-bold text-dark mb-1">No matching venues found</h4>
                <p class="text-muted mb-4">No partnered event facilities match your active search filter.</p>
                @if (AuthState.IsAdmin)
                {
                    <a href="/venues/create" class="btn btn-primary fw-bold px-4 py-2 shadow-sm">Add Venue</a>
                }
            </div>
        }
        else
        {
            <div class="row g-4">
                @foreach (var venue in _filteredVenues)
                {
                    <div class="col-md-6 col-lg-4">
                        <div class="modern-card card border-0 shadow-sm rounded-4 h-100 p-4 bg-white d-flex flex-column">
                            <div class="d-flex justify-content-between align-items-center mb-3">
                                <span class="badge bg-light text-secondary border px-3 py-1 rounded-pill shadow-sm">
                                    <i class="bi bi-building me-1"></i> Venue
                                </span>
                                <span class="badge bg-success px-3 py-1 rounded-pill shadow-sm">
                                    Active Partner
                                </span>
                            </div>

                            <h3 class="h5 fw-bold text-dark mb-1">@venue.Name</h3>
                            <p class="text-muted small mb-4 flex-grow-1">
                                <i class="bi bi-geo-alt text-danger me-1"></i> @venue.Location
                            </p>

                            <!-- Enterprise Venue Specifications Console -->
                            <div class="border-top pt-3 mt-auto">
                                <div class="d-flex justify-content-between mb-2">
                                    <span class="text-muted small fw-bold">Max Seating Capacity</span>
                                    <strong class="text-dark fw-bold small">@venue.MaxCapacity seats</strong>
                                </div>
                                <div class="d-flex justify-content-between mb-4">
                                    <span class="text-muted small fw-bold">Active Scheduled Events</span>
                                    <strong class="text-primary fw-bold small">@venue.EventCount event(s)</strong>
                                </div>

                                @if (AuthState.IsAdmin)
                                {
                                    <div class="d-flex gap-2 pt-2 border-top">
                                        <a href="/venues/edit/@venue.Id"
                                           class="btn btn-sm btn-outline-secondary flex-grow-1 fw-bold py-2 shadow-sm">
                                            <i class="bi bi-pencil me-1"></i> Edit
                                        </a>
                                        <button class="btn btn-sm btn-outline-danger px-3 py-2 fw-bold shadow-sm"
                                                @onclick="() => ShowDelete(venue.Id, venue.Name)">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    }
</div>

<ConfirmDialog IsVisible="@_showDelete"
               Title="Delete Venue"
               Message="@($"Delete '{_deleteName}'?")"
               OnConfirm="DoDelete"
               OnCancel="@(() => _showDelete = false)" />

@code {
    private List<VenueViewModel> _venues = new();
    private bool _loading = true;
    private string _searchTerm = string.Empty;
    private bool _showDelete;
    private int _deleteId;
    private string _deleteName = string.Empty;
    private string _success = string.Empty;
    private string _error = string.Empty;

    private List<VenueViewModel> _filteredVenues => string.IsNullOrWhiteSpace(_searchTerm)
        ? _venues
        : _venues.Where(v => 
            v.Name.Contains(_searchTerm, StringComparison.OrdinalIgnoreCase) || 
            v.Location.Contains(_searchTerm, StringComparison.OrdinalIgnoreCase) ||
            v.City.Contains(_searchTerm, StringComparison.OrdinalIgnoreCase)
          ).ToList();

    protected override async Task OnInitializedAsync()
    {
        AuthState.OnAuthStateChanged += AuthChanged;
        await Load();
    }
    private async void AuthChanged() => await InvokeAsync(StateHasChanged);

    private async Task Load()
    {
        try
        {
            _loading = true;
            var all = await VenueService.GetAllVenuesAsync();
            _venues = all.Select(VenueViewModel.FromEntity).ToList();
        }
        finally { _loading = false; }
    }

    private void ShowDelete(int id, string name)
    {
        if (!AuthState.IsAdmin) { _error = "Admin access required."; return; }
        _deleteId = id; _deleteName = name; _showDelete = true;
    }

    private async Task DoDelete()
    {
        if (!AuthState.IsAdmin) { _error = "Admin access required."; return; }
        try
        {
            _showDelete = false;
            await VenueService.DeleteVenueAsync(_deleteId);
            _success = $"Venue '{_deleteName}' deleted.";
            await Load();
        }
        catch (Exception ex) { _error = ex.Message; }
    }

    public void Dispose() => AuthState.OnAuthStateChanged -= AuthChanged;
}