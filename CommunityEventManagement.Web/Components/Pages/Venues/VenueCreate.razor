@* FILE: CommunityEventManagement.Web/Components/Pages/Venues/VenueCreate.razor *@
@* REPLACE ENTIRE FILE – adds Auth gating *@
@page "/venues/create"
@page "/venues/edit/{Id:int}"
@using CommunityEventManagement.Web.Services
@inject IVenueService VenueService
@inject AuthStateService AuthState
@inject NavigationManager Navigation

<PageTitle>@(Id == 0 ? "Add Venue" : "Edit Venue")</PageTitle>

@if (!AuthState.IsAdmin)
{
    <div class="container py-5">
        <div class="alert alert-danger">
            <h5><i class="bi bi-shield-exclamation"></i> Admin Access Required</h5>
            <p>Only administrators can manage venues.</p>
            <a href="/login" class="btn btn-primary btn-sm">Login</a>
            <a href="/venues" class="btn btn-outline-secondary btn-sm">Back</a>
        </div>
    </div>
}
else
{
<div class="page-header">
    <div class="container">
        <h1 class="fw-bold mb-0">
            <i class="bi bi-geo-alt"></i>
            @(Id == 0 ? "Add Venue" : "Edit Venue")
        </h1>
        <small class="text-light opacity-75">Admin: @AuthState.CurrentUser.FullName</small>
    </div>
</div>

<div class="container pb-5">
    <div class="row justify-content-center">
        <div class="col-lg-6">
            <div class="card shadow-sm">
                <div class="card-body p-4">
                    <AlertMessage Message="@_error" Type="danger"
                                  OnDismissed="@(()=>_error=string.Empty)" />

                    <EditForm Model="_model" OnValidSubmit="HandleSubmit">
                        <DataAnnotationsValidator />
                        <ValidationSummary class="alert alert-warning" />

                        <div class="mb-3">
                            <label class="form-label fw-semibold">
                                Venue Name *
                            </label>
                            <InputText @bind-Value="_model.Name"
                                       class="form-control" />
                            <ValidationMessage For="@(()=>_model.Name)"
                                               class="text-danger small" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-semibold">
                                Street Address *
                            </label>
                            <InputText @bind-Value="_model.Address"
                                       class="form-control" />
                            <ValidationMessage For="@(()=>_model.Address)"
                                               class="text-danger small" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-semibold">City *</label>
                            <InputText @bind-Value="_model.City"
                                       class="form-control" />
                            <ValidationMessage For="@(()=>_model.City)"
                                               class="text-danger small" />
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-semibold">
                                Maximum Capacity *
                            </label>
                            <InputNumber @bind-Value="_model.MaxCapacity"
                                         class="form-control" />
                            <ValidationMessage For="@(()=>_model.MaxCapacity)"
                                               class="text-danger small" />
                        </div>

                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-primary"
                                    disabled="@_submitting">
                                <i class="bi bi-check-circle"></i>
                                @(Id == 0 ? "Add Venue" : "Save Changes")
                            </button>
                            <a href="/venues" class="btn btn-outline-secondary">
                                <i class="bi bi-x"></i> Cancel
                            </a>
                        </div>
                    </EditForm>
                </div>
            </div>
        </div>
    </div>
</div>
}

@code {
    [Parameter] public int Id { get; set; }
    private CreateVenueModel _model = new();
    private bool _submitting;
    private string _error = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        if (!AuthState.IsAdmin)
        {
            Navigation.NavigateTo($"/login?returnUrl=/venues/{(Id==0?"create":"edit/"+Id)}");
            return;
        }
        if (Id != 0)
        {
            var v = await VenueService.GetVenueByIdAsync(Id);
            if (v != null) _model = CreateVenueModel.FromEntity(v);
        }
    }

    private async Task HandleSubmit()
    {
        if (!AuthState.IsAdmin) { _error = "Admin access required."; return; }
        try
        {
            _submitting = true;
            if (Id == 0)
                await VenueService.CreateVenueAsync(
                    _model.Name, _model.Address, _model.City, _model.MaxCapacity);
            else
                await VenueService.UpdateVenueAsync(
                    Id, _model.Name, _model.Address, _model.City, _model.MaxCapacity);

            Navigation.NavigateTo("/venues");
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { _submitting = false; }
    }
}
