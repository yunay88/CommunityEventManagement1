@page "/events/{Id:int}"
@using CommunityEventManagement.Web.Services
@inject IEventService EventService
@inject IRegistrationService RegistrationService
@inject IParticipantService ParticipantService
@inject AuthStateService AuthState
@inject NavigationManager Navigation
@implements IDisposable

<PageTitle>@(_event?.Name ?? "Event Detail")</PageTitle>

<div class="page-header-console bg-white border-bottom py-4 px-5 d-flex justify-content-between align-items-center shadow-sm mb-5">
    <div>
        <nav aria-label="breadcrumb" class="mb-1">
            <ol class="breadcrumb mb-0">
                <li class="breadcrumb-item"><a href="/events" class="text-decoration-none text-muted small fw-semibold">Events</a></li>
                <li class="breadcrumb-item active small fw-bold" aria-current="page">@(_event?.Name ?? "Detail")</li>
            </ol>
        </nav>
        <h1 class="h3 fw-bold text-dark mb-0">@(_event?.Name ?? "Event Specification")</h1>
    </div>
    <div class="d-flex gap-2">
        @if (AuthState.IsAdmin && _event != null)
        {
            <a href="/events/edit/@_event.Id" class="btn btn-outline-secondary py-2 fw-bold shadow-sm">
                <i class="bi bi-pencil me-2"></i> Edit event
            </a>
        }
        <a href="/events" class="btn btn-outline-secondary py-2 fw-bold shadow-sm">
            <i class="bi bi-arrow-left me-2"></i> Back to list
        </a>
    </div>
</div>

<div class="container pb-5">
    @if (!string.IsNullOrEmpty(_errorMessage))
    {
        <div class="alert alert-danger mb-4 d-flex align-items-center shadow-sm">
            <i class="bi bi-exclamation-triangle-fill me-2 fs-5"></i>
            <div><strong>Error:</strong> @_errorMessage</div>
        </div>
    }
    @if (!string.IsNullOrEmpty(_successMessage))
    {
        <div class="alert alert-success mb-4 d-flex align-items-center shadow-sm">
            <i class="bi bi-check-circle-fill me-2 fs-5"></i>
            <div><strong>Success:</strong> @_successMessage</div>
        </div>
    }

    @if (_isLoading)
    {
        <div class="d-flex justify-content-center my-5">
            <div class="spinner-border text-primary" role="status"></div>
        </div>
    }
    else if (_event == null)
    {
        <div class="modern-container card border-0 shadow-sm rounded-4 p-5 text-center bg-white">
            <i class="bi bi-question-circle display-4 text-muted mb-3 d-block"></i>
            <h4 class="fw-bold text-dark mb-2">Event not found</h4>
            <p class="text-muted mb-4">The event you are looking for does not exist or has been removed.</p>
            <a href="/events" class="btn btn-outline-secondary py-2 fw-bold shadow-sm">Return to events</a>
        </div>
    }
    else
    {
        var primaryVenue = _event.Venues?.FirstOrDefault(v => v.IsPrimary) ?? _event.Venues?.FirstOrDefault();
        var confirmedCount = _event.Registrations?.Count(r => r.Status == CommunityEventManagement.Domain.Enums.RegistrationStatus.Confirmed) ?? 0;
        var maxCapacity = primaryVenue?.Capacity ?? int.MaxValue;
        var availableSeats = Math.Max(0, maxCapacity - confirmedCount);
        var isEventFull = primaryVenue != null && availableSeats == 0;

        <div class="row g-5">
            <!-- Main Content Grid -->
            <div class="col-lg-8">
                <div class="modern-container card border-0 shadow-sm rounded-4 p-4 mb-5 bg-white">
                    <div class="d-flex align-items-center justify-content-between mb-4 pb-3 border-bottom">
                        <h2 class="h5 fw-bold text-dark mb-0 d-flex align-items-center">
                            <i class="bi bi-info-square text-primary me-2"></i> Event Specification
                        </h2>
                        <span class="badge bg-primary px-3 py-2 rounded-pill shadow-sm">@_event.StatusBadge</span>
                    </div>
                    @if (!string.IsNullOrWhiteSpace(_event.Description))
                    {
                        <p class="text-muted mb-4">@_event.Description</p>
                    }
                    <dl class="row mb-0 pt-3 border-top">
                        <dt class="col-sm-3 text-muted fw-bold small mb-2 mb-sm-0 d-flex align-items-center">
                            <i class="bi bi-calendar-event me-2 text-primary opacity-75"></i> Start Time
                        </dt>
                        <dd class="col-sm-9 text-dark mb-3 fw-semibold">@_event.StartDate.ToString("ddd dd MMM yyyy, HH:mm")</dd>

                        <dt class="col-sm-3 text-muted fw-bold small mb-2 mb-sm-0 d-flex align-items-center">
                            <i class="bi bi-calendar-check me-2 text-primary opacity-75"></i> End Time
                        </dt>
                        <dd class="col-sm-9 text-dark mb-3 fw-semibold">@_event.EndDate.ToString("ddd dd MMM yyyy, HH:mm")</dd>

                        <dt class="col-sm-3 text-muted fw-bold small mb-2 mb-sm-0 d-flex align-items-center">
                            <i class="bi bi-stopwatch me-2 text-primary opacity-75"></i> Duration
                        </dt>
                        <dd class="col-sm-9 text-dark mb-4 fw-semibold">@_event.DurationFormatted</dd>

                        @if (_event.Venues?.Any() == true)
                        {
                            <dt class="col-sm-3 text-muted fw-bold small mb-2 mb-sm-0 d-flex align-items-start">
                                <i class="bi bi-geo-alt me-2 text-danger opacity-75 mt-1"></i> Venue@((_event.Venues.Count > 1) ? "s" : "")
                            </dt>
                            <dd class="col-sm-9 text-dark mb-0">
                                @foreach (var v in _event.Venues)
                                {
                                    var vAvailable = Math.Max(0, v.Capacity - confirmedCount);
                                    <div class="mb-3 p-4 bg-slate-50 border rounded-4 shadow-sm">
                                        <div class="d-flex align-items-center justify-content-between mb-2">
                                            <strong class="text-dark fs-6">
                                                @v.Name
                                                @if (v.IsPrimary) { <span class="badge bg-primary px-2 py-1 rounded-pill ms-2 shadow-sm small">Primary Venue</span> }
                                            </strong>
                                            <span class="badge @(vAvailable == 0 ? "bg-danger" : "bg-success") px-2 py-1 rounded-pill shadow-sm small">
                                                @(vAvailable == 0 ? "Fully Booked" : "Available")
                                            </span>
                                        </div>
                                        <div class="text-muted small mb-2 fw-medium"><i class="bi bi-geo text-secondary me-1"></i> @v.Location</div>
                                        <div class="pt-2 border-top d-flex justify-content-between text-secondary small fw-bold">
                                            <span>Available Seats for this Event</span>
                                            <span>@(vAvailable == 0 ? $"Fully Booked (0 available out of {v.Capacity})" : $"{vAvailable} available out of {v.Capacity}")</span>
                                        </div>
                                    </div>
                                }
                            </dd>
                        }
                    </dl>
                </div>

                <!-- Activities Module -->
                @if (_event.Activities?.Any() == true)
                {
                    <div class="modern-container card border-0 shadow-sm rounded-4 p-4 mb-5 bg-white">
                        <h2 class="h5 fw-bold text-dark mb-4 pb-3 border-bottom d-flex align-items-center">
                            <i class="bi bi-lightning-charge text-warning me-2"></i> Activities (@_event.Activities.Count)
                        </h2>
                        <div class="row g-3">
                            @foreach (var activity in _event.Activities)
                            {
                                <div class="col-md-6">
                                    <div class="border rounded-4 p-3 d-flex align-items-center justify-content-between bg-light shadow-sm">
                                        <div>
                                            <div class="fw-bold text-dark mb-1">@activity.Name</div>
                                            <span class="badge bg-secondary px-2 py-1 rounded-pill shadow-sm">@activity.TypeName</span>
                                        </div>
                                        <span class="text-muted small fw-bold d-flex align-items-center">
                                            <i class="bi bi-clock me-1 opacity-75"></i> @activity.DurationFormatted
                                        </span>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                }

                <!-- Registrations Table Console (Admin only) -->
                @if (AuthState.IsAdmin && _event.Registrations?.Any() == true)
                {
                    <div class="modern-container card border-0 shadow-sm rounded-4 mb-5 bg-white overflow-hidden">
                        <div class="p-4 border-bottom d-flex align-items-center justify-content-between">
                            <h2 class="h5 fw-bold text-dark mb-0 d-flex align-items-center">
                                <i class="bi bi-people text-success me-2"></i> Registered Participants
                            </h2>
                            <span class="badge bg-secondary px-3 py-1 rounded-pill shadow-sm">@_event.Registrations.Count Total</span>
                        </div>
                        <table class="table table-hover mb-0 align-middle">
                            <thead class="table-light">
                                <tr>
                                    <th class="ps-4">Participant</th>
                                    <th>Email</th>
                                    <th>Registration Date</th>
                                    <th>Status</th>
                                    <th class="pe-4 text-end">Action</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var reg in _event.Registrations)
                                {
                                    <tr>
                                        <td class="ps-4 fw-bold text-dark">@reg.ParticipantName</td>
                                        <td class="text-muted">@reg.ParticipantEmail</td>
                                        <td class="text-muted">@reg.RegistrationDate.ToString("dd/MM/yyyy")</td>
                                        <td>
                                            <span class="badge @(reg.Status == CommunityEventManagement.Domain.Enums.RegistrationStatus.Confirmed ? "bg-success" : reg.Status == CommunityEventManagement.Domain.Enums.RegistrationStatus.Waitlisted ? "bg-info" : "bg-danger") px-2 py-1 rounded-pill shadow-sm">@reg.StatusName</span>
                                        </td>
                                        <td class="pe-4 text-end">
                                            @if (reg.Status == CommunityEventManagement.Domain.Enums.RegistrationStatus.Waitlisted)
                                            {
                                                <button class="btn btn-sm btn-success py-1 px-3 fw-bold shadow-sm me-1"
                                                        @onclick="() => ApproveRegistrationAsync(reg.Id)">
                                                    <i class="bi bi-check-lg"></i> Approve
                                                </button>
                                            }
                                            @if (reg.Status != CommunityEventManagement.Domain.Enums.RegistrationStatus.Cancelled)
                                            {
                                                <button class="btn btn-sm btn-outline-danger py-1 px-3 fw-bold shadow-sm"
                                                        @onclick="() => CancelRegistration(reg.Id)">
                                                    Cancel
                                                </button>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>

            <!-- Registration Action Sidebar -->
            <div class="col-lg-4">
                <div class="modern-container card border-0 shadow-sm rounded-4 p-4 bg-white sticky-top" style="top: 2rem;">
                    <h2 class="h5 fw-bold text-dark mb-4 pb-3 border-bottom d-flex align-items-center">
                        <i class="bi bi-shield-check text-primary me-2"></i> Registration Console
                    </h2>
                    @if (!AuthState.IsAuthenticated)
                    {
                        <p class="text-muted small mb-4 fw-medium">Sign in to your participant account to secure your place at this event.</p>
                        <a href="/login?returnUrl=/events/@Id" class="btn btn-primary w-100 py-2 fw-bold shadow-sm d-inline-flex align-items-center justify-content-center">
                            <i class="bi bi-box-arrow-in-right me-2"></i> Sign in to register
                        </a>
                    }
                    else if (AuthState.IsAdmin)
                    {
                        <div class="p-3 bg-light border rounded-3 mb-0 shadow-sm">
                            <p class="text-muted small mb-0 d-flex align-items-center fw-medium">
                                <i class="bi bi-info-circle text-primary me-2 fs-5"></i>
                                As an administrator, you manage participant registrations directly from the table console on the left.
                            </p>
                            @if (primaryVenue != null)
                            {
                                <div class="mt-3 pt-3 border-top d-flex justify-content-between align-items-center small fw-bold">
                                    <span>Primary Venue Status</span>
                                    <span class="text-@(isEventFull ? "danger" : "success")">
                                        @(isEventFull ? "Fully Booked (0 left)" : $"{availableSeats} seats left for this event")
                                    </span>
                                </div>
                            }
                        </div>
                    }
                    else if (_isRegistered)
                    {
                        <div class="p-3 bg-success-subtle text-success border border-success-subtle rounded-3 fw-bold small mb-4 d-flex align-items-center shadow-sm">
                            <i class="bi bi-check-circle-fill me-2 fs-5"></i> You are actively registered for this event.
                        </div>
                        <button class="btn btn-outline-danger w-100 py-2 fw-bold shadow-sm d-inline-flex align-items-center justify-content-center"
                                @onclick="CancelMyRegistration"
                                disabled="@_isRegistering">
                            @if (_isRegistering) { <span class="spinner-border spinner-border-sm me-2"></span> }
                            <i class="bi bi-x-lg me-2"></i> Cancel registration
                        </button>
                    }
                    else
                    {
                        <div class="mb-4 p-3 bg-light border rounded-4 shadow-sm">
                            <div class="text-muted small mb-1 fw-bold">Registering Account</div>
                            <div class="fw-bold text-dark fs-6">@AuthState.CurrentUser.FullName</div>
                            <div class="text-muted small fw-medium mb-3">@AuthState.CurrentUser.Email</div>

                            @if (primaryVenue != null)
                            {
                                <div class="pt-3 border-top d-flex justify-content-between align-items-center small fw-bold">
                                    <span>Available Seats for Event</span>
                                    <span class="badge @(isEventFull ? "bg-danger" : "bg-success") px-2 py-1 rounded-pill shadow-sm">
                                        @(isEventFull ? "Fully Booked (0 left)" : $"{availableSeats} / {primaryVenue.Capacity}")
                                    </span>
                                </div>
                            }
                        </div>
                        <button class="btn @(isEventFull ? "btn-warning" : "btn-primary") w-100 py-2 fw-bold shadow-sm d-inline-flex align-items-center justify-content-center"
                                @onclick="RegisterMe"
                                disabled="@_isRegistering">
                            @if (_isRegistering) 
                            { 
                                <span class="spinner-border spinner-border-sm me-2"></span> 
                                <span>Processing...</span>
                            }
                            else if (isEventFull)
                            {
                                <i class="bi bi-clock-history me-2 fs-5"></i> <span>Add me to waitlist</span>
                            }
                            else
                            {
                                <i class="bi bi-check2-square me-2 fs-5"></i> <span>Confirm registration</span>
                            }
                        </button>
                    }
                    <div class="pt-4 mt-4 border-top text-muted small text-center d-flex align-items-center justify-content-center fw-bold">
                        <i class="bi bi-people me-2 text-primary opacity-75"></i> @confirmedCount participant(s) currently confirmed
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@code {
    [Parameter] public int Id { get; set; }

    private EventDetailViewModel? _event;
    private bool _isLoading = true;
    private bool _isRegistering = false;
    private string _errorMessage = string.Empty;
    private string _successMessage = string.Empty;
    private bool _isRegistered = false;
    private int? _myRegistrationId;

    protected override async Task OnInitializedAsync()
    {
        AuthState.OnAuthStateChanged += AuthChanged;
        await LoadAsync();
    }

    private async void AuthChanged() => await InvokeAsync(async () => await LoadAsync());

    private async Task LoadAsync()
    {
        try
        {
            _isLoading = true;
            _errorMessage = string.Empty;

            var entity = await EventService.GetEventWithDetailsAsync(Id);

            if (entity != null)
            {
                _event = EventDetailViewModel.FromEntity(entity);
                await CheckMyRegistrationAsync();
            }
            else
            {
                _event = null;
                _errorMessage = $"Event with ID {Id} was not found in the database.";
            }
        }
        catch (Exception ex)
        {
            _event = null;
            _errorMessage = $"Failed to load event: {ex.Message}";
        }
        finally
        {
            _isLoading = false;
            StateHasChanged();
        }
    }

    private async Task CheckMyRegistrationAsync()
    {
        _isRegistered = false;
        _myRegistrationId = null;

        if (AuthState.IsAuthenticated && AuthState.UserId.HasValue && _event?.Registrations != null)
        {
            var myReg = _event.Registrations.FirstOrDefault(r =>
                string.Equals(r.ParticipantEmail, AuthState.CurrentUser.Email,
                    StringComparison.OrdinalIgnoreCase) &&
                r.Status != CommunityEventManagement.Domain.Enums.RegistrationStatus.Cancelled);

            if (myReg != null)
            {
                _isRegistered = true;
                _myRegistrationId = myReg.Id;
            }
        }
        await Task.CompletedTask;
    }

    private async Task RegisterMe()
    {
        if (!AuthState.IsAuthenticated || !AuthState.UserId.HasValue)
        {
            Navigation.NavigateTo($"/login?returnUrl=/events/{Id}");
            return;
        }
        try
        {
            _isRegistering = true;
            _errorMessage = string.Empty;
            _successMessage = string.Empty;

            var reg = await RegistrationService.RegisterParticipantAsync(AuthState.UserId.Value, Id);
            _successMessage = reg.Status == CommunityEventManagement.Domain.Enums.RegistrationStatus.Waitlisted 
                ? "The venue is at full capacity for this event. You have been successfully added to the waitlist queue."
                : "Your registration has been successfully confirmed!";
            await LoadAsync();
        }
        catch (CommunityEventManagement.Domain.Exceptions.DuplicateRegistrationException)
        {
            await LoadAsync();
        }
        catch (Exception ex)
        {
            _errorMessage = $"Registration failed: {ex.Message}";
        }
        finally
        {
            _isRegistering = false;
        }
    }

    private async Task CancelMyRegistration()
    {
        if (!_myRegistrationId.HasValue) return;
        try
        {
            _isRegistering = true;
            _errorMessage = string.Empty;
            _successMessage = string.Empty;

            await RegistrationService.CancelRegistrationAsync(_myRegistrationId.Value, "Cancelled by participant");
            _successMessage = "Your registration has been successfully cancelled.";
            await LoadAsync();
        }
        catch (Exception ex)
        {
            _errorMessage = $"Cancel failed: {ex.Message}";
        }
        finally
        {
            _isRegistering = false;
        }
    }

    private async Task CancelRegistration(int registrationId)
    {
        if (!AuthState.IsAdmin) return;
        try
        {
            _errorMessage = string.Empty;
            _successMessage = string.Empty;
            await RegistrationService.CancelRegistrationAsync(registrationId, "Cancelled by admin");
            _successMessage = "Participant registration cancelled successfully.";
            await LoadAsync();
        }
        catch (Exception ex)
        {
            _errorMessage = $"Cancel failed: {ex.Message}";
        }
    }

    private async Task ApproveRegistrationAsync(int registrationId)
    {
        if (!AuthState.IsAdmin) return;
        try
        {
            _errorMessage = string.Empty;
            _successMessage = string.Empty;
            await RegistrationService.ConfirmRegistrationAsync(registrationId);
            _successMessage = "Participant successfully promoted from waitlist to confirmed status!";
            await LoadAsync();
        }
        catch (Exception ex)
        {
            _errorMessage = $"Approval failed: {ex.Message}";
        }
    }

    public void Dispose()
    {
        AuthState.OnAuthStateChanged -= AuthChanged;
    }
}