@page "/events"
@using CommunityEventManagement.Infrastructure.Patterns.Facade
@using CommunityEventManagement.Domain.Interfaces.Services
@using CommunityEventManagement.Web.ViewModels
@using CommunityEventManagement.Web.Services
@inject IEventService EventService
@inject IVenueService VenueService
@inject AuthStateService AuthState
@inject NavigationManager Navigation
@implements IDisposable

<PageTitle>Events Catalog — Community Events</PageTitle>

<div class="page-header-console bg-white border-bottom py-4 px-5 d-flex justify-content-between align-items-center shadow-sm mb-5">
    <div>
        <h1 class="h3 fw-bold text-dark mb-1">Events Catalog</h1>
        <p class="text-muted small mb-0">Explore, search, and filter upcoming community events.</p>
    </div>
    @if (AuthState.IsAdmin)
    {
        <a href="/events/create" class="btn btn-primary fw-bold shadow-sm px-4 py-2">
            <i class="bi bi-plus-lg me-2"></i> Create Event
        </a>
    }
</div>

<div class="container pb-5">
    <AlertMessage Message="@_successMessage" Type="success" OnDismissed="@(() => _successMessage = string.Empty)" />
    <AlertMessage Message="@_errorMessage" Type="danger" OnDismissed="@(() => _errorMessage = string.Empty)" />

    <!-- Modern Filter Console -->
    <div class="modern-container card border-0 shadow-sm rounded-4 p-4 mb-5 bg-white">
        <div class="d-flex align-items-center mb-3 pb-2 border-bottom">
            <i class="bi bi-funnel text-primary me-2 fs-5"></i>
            <h6 class="mb-0 fw-bold text-dark">Filter Specifications</h6>
        </div>
        <div class="row g-3 align-items-end">
            <div class="col-md-3">
                <label class="form-label small fw-bold text-muted mb-1">Search</label>
                <div class="input-group">
                    <span class="input-group-text bg-transparent border-end-0 text-muted"><i class="bi bi-search"></i></span>
                    <input class="form-control border-start-0 ps-0" placeholder="Search events..."
                           @bind="_filter.SearchTerm"
                           @bind:event="oninput" />
                </div>
            </div>
            <div class="col-md-2">
                <label class="form-label small fw-bold text-muted mb-1">From Date</label>
                <input type="date" class="form-control" @bind="_filter.StartDate" />
            </div>
            <div class="col-md-2">
                <label class="form-label small fw-bold text-muted mb-1">To Date</label>
                <input type="date" class="form-control" @bind="_filter.EndDate" />
            </div>
            <div class="col-md-2">
                <label class="form-label small fw-bold text-muted mb-1">Venue</label>
                <select class="form-select" @bind="_filter.VenueId">
                    <option value="">All venues</option>
                    @foreach (var venue in _venues)
                    {
                        <option value="@venue.Id">@venue.Name</option>
                    }
                </select>
            </div>
            <div class="col-md-2">
                <label class="form-label small fw-bold text-muted mb-1">Activity Type</label>
                <select class="form-select" @bind="_filter.ActivityType">
                    <option value="">All types</option>
                    @foreach (var type in Enum.GetValues<ActivityType>())
                    {
                        <option value="@type">@type</option>
                    }
                </select>
            </div>
            <div class="col-md-1">
                <button class="btn btn-primary w-100 py-2 fw-bold shadow-sm d-flex align-items-center justify-content-center" @onclick="ApplyFilter">
                    <i class="bi bi-arrow-right fs-5"></i>
                </button>
            </div>
        </div>
        @if (_filter.HasFilters)
        {
            <div class="pt-3 mt-3 border-top d-flex justify-content-between align-items-center">
                <span class="text-muted small d-flex align-items-center"><i class="bi bi-check2-circle text-primary me-2"></i> Filters actively applied</span>
                <button class="btn btn-sm btn-outline-secondary py-1 px-3 fw-bold shadow-sm" @onclick="ClearFilter">Reset filters</button>
            </div>
        }
    </div>

    <LoadingSpinner IsLoading="@_isLoading" />

    @if (!_isLoading)
    {
        <div class="d-flex justify-content-between align-items-center mb-4">
            <span class="text-muted small fw-bold">
                Showing @_events.Count event(s)
            </span>
            @if (!AuthState.IsAuthenticated)
            {
                <span class="text-muted small">
                    <a href="/login" class="text-primary text-decoration-none fw-bold">Sign in</a> to register for events
                </span>
            }
        </div>

        @if (!_events.Any())
        {
            <div class="modern-container card border-0 shadow-sm rounded-4 p-5 text-center bg-white">
                <i class="bi bi-search display-4 text-muted mb-3 d-block"></i>
                <h4 class="fw-bold text-dark mb-1">No matching events</h4>
                <p class="text-muted mb-4">Try adjusting or resetting your filter criteria.</p>
                @if (AuthState.IsAdmin)
                {
                    <a href="/events/create" class="btn btn-primary fw-bold px-4 py-2 shadow-sm">Create Event</a>
                }
            </div>
        }
        else
        {
            <div class="row g-4">
                @foreach (var evt in _events)
                {
                    <div class="col-md-6 col-lg-4">
                        <div class="modern-card card border-0 shadow-sm rounded-4 h-100 p-4 bg-white d-flex flex-column">
                            <div class="d-flex justify-content-between align-items-center mb-3">
                                <span class="badge bg-primary px-3 py-2 rounded-pill shadow-sm">@evt.StatusBadge</span>
                                <span class="text-muted small fw-semibold d-flex align-items-center">
                                    <i class="bi bi-stopwatch me-1 opacity-75"></i> @evt.DurationFormatted
                                </span>
                            </div>
                            <h3 class="h5 fw-bold text-dark mb-2">@evt.Name</h3>
                            <p class="text-muted small mb-4 flex-grow-1">
                                @(evt.Description.Length > 100 ? evt.Description[..100] + "..." : evt.Description)
                            </p>
                            <div class="border-top pt-3 mt-auto">
                                <div class="text-muted small mb-2 d-flex align-items-center fw-medium">
                                    <i class="bi bi-calendar3 text-primary me-2 opacity-75"></i>
                                    @evt.StartDate.ToString("ddd dd MMM yyyy, HH:mm")
                                </div>
                                @if (!string.IsNullOrEmpty(evt.VenueName))
                                {
                                    <div class="text-muted small mb-3 d-flex align-items-center fw-medium">
                                        <i class="bi bi-geo-alt text-danger me-2 opacity-75"></i>
                                        @evt.VenueName
                                    </div>
                                }
                                <div class="d-flex gap-2 mt-4">
                                    <a href="/events/@evt.Id" class="btn btn-outline-secondary flex-grow-1 py-2 fw-bold shadow-sm">
                                        View details
                                    </a>
                                    @if (AuthState.IsAdmin)
                                    {
                                        <a href="/events/edit/@evt.Id" class="btn btn-outline-secondary px-3 py-2 shadow-sm">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                        <button class="btn btn-outline-danger px-3 py-2 shadow-sm"
                                                @onclick="() => ShowDeleteConfirm(evt.Id, evt.Name)">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    }
</div>

<ConfirmDialog IsVisible="@_showDeleteDialog"
               Title="Delete Event"
               Message="@($"Are you sure you want to delete '{_deleteEventName}'? This cannot be undone.")"
               ConfirmText="Delete"
               OnConfirm="ConfirmDelete"
               OnCancel="@(() => _showDeleteDialog = false)" />

@code {
    private List<EventViewModel> _events = new();
    private List<VenueViewModel> _venues = new();
    private EventFilterModel _filter = new();
    private bool _isLoading = true;
    private string _successMessage = string.Empty;
    private string _errorMessage = string.Empty;
    private bool _showDeleteDialog = false;
    private int _deleteEventId;
    private string _deleteEventName = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        AuthState.OnAuthStateChanged += AuthChanged;
        await LoadDataAsync();
    }

    private async void AuthChanged() => await InvokeAsync(StateHasChanged);

    private async Task LoadDataAsync()
    {
        try
        {
            _isLoading = true;
            var events = await EventService.FilterEventsAsync(_filter.ToFilterCriteria());
            _events = events.Select(EventViewModel.FromEntity).ToList();

            var venues = await VenueService.GetAllVenuesAsync();
            _venues = venues.Select(VenueViewModel.FromEntity).ToList();
        }
        catch (Exception ex)
        {
            _errorMessage = $"Error loading events: {ex.Message}";
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task ApplyFilter() => await LoadDataAsync();

    private async Task ClearFilter()
    {
        _filter = new EventFilterModel();
        await LoadDataAsync();
    }

    private void ShowDeleteConfirm(int id, string name)
    {
        if (!AuthState.IsAdmin)
        {
            _errorMessage = "Admin access required.";
            return;
        }
        _deleteEventId = id;
        _deleteEventName = name;
        _showDeleteDialog = true;
    }

    private async Task ConfirmDelete()
    {
        try
        {
            _showDeleteDialog = false;
            await EventService.DeleteEventAsync(_deleteEventId);
            _successMessage = $"Event '{_deleteEventName}' deleted successfully.";
            await LoadDataAsync();
        }
        catch (Exception ex)
        {
            _errorMessage = $"Error deleting event: {ex.Message}";
        }
    }

    public void Dispose()
    {
        AuthState.OnAuthStateChanged -= AuthChanged;
    }
}