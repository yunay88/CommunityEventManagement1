@page "/events/edit/{Id:int}"
@inject IEventService EventService
@inject IVenueService VenueService
@inject AuthStateService AuthState
@inject NavigationManager Navigation

<PageTitle>Edit Event</PageTitle>

@if (!AuthState.IsAdmin)
{
    <div class="alert alert-danger">
        <h5>Admin Access Required</h5>
        <p>Only administrators can edit events.</p>
        <a href="/login" class="btn btn-primary btn-sm">Login</a>
    </div>
}
else
{
<h2 class="fw-bold mb-3">Edit Event</h2>

@if (!string.IsNullOrEmpty(_errorMessage))
{
    <div class="alert alert-danger">@_errorMessage</div>
}

@if (_isLoading)
{
    <p class="text-muted">Loading…</p>
}
else if (_model != null)
{
<div class="card">
    <div class="card-body">
        <EditForm Model="_model" OnValidSubmit="HandleSubmit">
            <DataAnnotationsValidator />
            <ValidationSummary class="alert alert-warning" />

            <div class="row mb-3">
                <div class="col-md-8">
                    <label class="form-label fw-semibold">Event Name <span class="text-danger">*</span></label>
                    <input @bind="_model.Name" class="form-control" />
                    <ValidationMessage For="@(() => _model.Name)" class="text-danger small" />
                </div>
            </div>

            <div class="mb-3">
                <label class="form-label fw-semibold">Description</label>
                <textarea @bind="_model.Description" class="form-control" rows="3"></textarea>
            </div>

            <div class="row mb-3">
                <div class="col-md-6">
                    <label class="form-label fw-semibold">Start Date & Time</label>
                    <input type="datetime-local" @bind="_model.StartDate" class="form-control" />
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-semibold">End Date & Time</label>
                    <input type="datetime-local" @bind="_model.EndDate" class="form-control" />
                </div>
            </div>

            <div class="mb-3">
                <label class="form-label fw-semibold">Venues</label>
                <small class="text-muted d-block mb-2">
                    The brief requires events to take place at <strong>various Venues</strong> (M:N).
                </small>
                <div class="border rounded p-3" style="max-height: 240px; overflow-y: auto;">
                    @foreach (var venue in _venues)
                    {
                        var isSelected = _model.SelectedVenueIds.Contains(venue.Id);
                        <div class="form-check mb-2">
                            <input type="checkbox"
                                   class="form-check-input"
                                   id="editvenue_@venue.Id"
                                   checked="@isSelected"
                                   @onchange="e => ToggleVenue(venue.Id, (bool)e.Value!)" />
                            <label class="form-check-label" for="editvenue_@venue.Id">
                                <strong>@venue.Name</strong>
                                <small class="text-muted">— @venue.City (Capacity: @venue.MaxCapacity)</small>
                                @if (isSelected)
                                {
                                    <span class="badge bg-primary ms-2">Selected</span>
                                    @if (_model.PrimaryVenueId == venue.Id)
                                    {
                                        <span class="badge bg-warning ms-1">Primary</span>
                                    }
                                    else
                                    {
                                        <button type="button"
                                                class="btn btn-sm btn-outline-warning ms-2"
                                                @onclick="() => SetPrimary(venue.Id)">
                                            Make Primary
                                        </button>
                                    }
                                }
                            </label>
                        </div>
                    }
                </div>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary" disabled="@_isSubmitting">
                    @if (_isSubmitting) { <span class="spinner-border spinner-border-sm me-2"></span> }
                    Save Changes
                </button>
                <a href="/events" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </EditForm>
    </div>
</div>
}
}

@code {
    [Parameter] public int Id { get; set; }

    private CreateEventModel? _model;
    private List<VenueViewModel> _venues = new();
    private bool _isLoading = true;
    private bool _isSubmitting = false;
    private string _errorMessage = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        if (!AuthState.IsAdmin)
        {
            Navigation.NavigateTo("/access-denied", forceLoad: true);
            return;
        }
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        try
        {
            var eventEntity = await EventService.GetEventWithDetailsAsync(Id);
            _venues = (await VenueService.GetAllVenuesAsync())
                .Select(VenueViewModel.FromEntity).ToList();

            if (eventEntity != null)
            {
                _model = new CreateEventModel
                {
                    Id = eventEntity.Id,
                    Name = eventEntity.Name ?? "",
                    Description = eventEntity.Description ?? "",
                    StartDate = eventEntity.StartDate,
                    EndDate = eventEntity.EndDate,
                    SelectedVenueIds = eventEntity.EventVenues?.Select(ev => ev.VenueId).ToList() ?? new(),
                    PrimaryVenueId = eventEntity.EventVenues?.FirstOrDefault(ev => ev.IsPrimary)?.VenueId,
                    SelectedActivityIds = eventEntity.EventActivities?.Select(ea => ea.ActivityId).ToList() ?? new()
                };
            }
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message;
        }
        finally
        {
            _isLoading = false;
        }
    }

    private void ToggleVenue(int venueId, bool isChecked)
    {
        if (isChecked && !_model!.SelectedVenueIds.Contains(venueId))
        {
            _model.SelectedVenueIds.Add(venueId);
            if (_model.SelectedVenueIds.Count == 1)
                _model.PrimaryVenueId = venueId;
        }
        else if (!isChecked)
        {
            _model!.SelectedVenueIds.Remove(venueId);
            if (_model.PrimaryVenueId == venueId)
                _model.PrimaryVenueId = _model.SelectedVenueIds.FirstOrDefault();
        }
    }

    private void SetPrimary(int venueId)
    {
        if (_model!.SelectedVenueIds.Contains(venueId))
            _model.PrimaryVenueId = venueId;
    }

    private async Task HandleSubmit()
    {
        if (_model == null) return;
        try
        {
            _isSubmitting = true;
            _errorMessage = string.Empty;

            if (_model.SelectedVenueIds.Count == 0)
            {
                _errorMessage = "Please select at least one venue.";
                return;
            }
            if (_model.PrimaryVenueId == null || !_model.SelectedVenueIds.Contains(_model.PrimaryVenueId.Value))
            {
                _errorMessage = "Please select a primary venue.";
                return;
            }

            await EventService.UpdateEventWithVenuesAsync(
                _model.Id,
                _model.Name,
                _model.Description,
                _model.StartDate,
                _model.EndDate,
                _model.SelectedVenueIds.ToList(),
                _model.PrimaryVenueId!.Value,
                _model.SelectedActivityIds.ToList());

            Navigation.NavigateTo($"/events/{Id}");
        }
        catch (Exception ex) { _errorMessage = ex.Message; }
        finally { _isSubmitting = false; }
    }
}