@using CommunityEventManagement.Web.Services
@inherits LayoutComponentBase
@inject AuthStateService AuthState
@inject NavigationManager Navigation
@implements IDisposable

@if (AuthState.IsAuthenticated)
{
    <!-- Vertical Sidebar Dashboard Portal -->
    <div class="portal-layout">
        <!-- Vertical Sidebar -->
        <aside class="portal-sidebar shadow-sm">
            <!-- Brand Header -->
            <div class="p-4 border-bottom d-flex align-items-center">
                <i class="bi bi-layers-fill text-primary fs-4 me-2"></i>
                <span class="fw-bold text-dark fs-5">Community Events</span>
            </div>

            <!-- Navigation Sections -->
            <div class="flex-grow-1 overflow-y-auto">
                <div class="portal-nav-group">
                    <div class="portal-nav-title">General</div>
                    <NavLink class="portal-nav-link" href="/" Match="NavLinkMatch.All">
                        <i class="bi bi-grid"></i> Overview
                    </NavLink>
                    <NavLink class="portal-nav-link" href="/events">
                        <i class="bi bi-calendar-range"></i> Events Catalog
                    </NavLink>
                </div>

                @if (!AuthState.IsAdmin)
                {
                    <div class="portal-nav-group">
                        <div class="portal-nav-title">Participant Portal</div>
                        <NavLink class="portal-nav-link" href="/registrations/my">
                            <i class="bi bi-ticket-perforated"></i> My Registrations
                        </NavLink>
                    </div>
                }

                @if (AuthState.IsAdmin)
                {
                    <div class="portal-nav-group">
                        <div class="portal-nav-title">Admin Portal</div>
                        <NavLink class="portal-nav-link" href="/participants">
                            <i class="bi bi-people"></i> Participants
                        </NavLink>
                        <NavLink class="portal-nav-link" href="/venues">
                            <i class="bi bi-geo-alt"></i> Venues
                        </NavLink>
                        <NavLink class="portal-nav-link" href="/activities">
                            <i class="bi bi-lightning-charge"></i> Activities
                        </NavLink>
                        <NavLink class="portal-nav-link" href="/registrations">
                            <i class="bi bi-card-checklist"></i> Registrations
                        </NavLink>
                    </div>
                }
            </div>

            <!-- User Footer Card -->
            <div class="p-3 border-top bg-light">
                <div class="d-flex align-items-center mb-3">
                    <div class="bg-white border rounded-circle d-flex align-items-center justify-content-center me-3 shadow-sm" style="width: 40px; height: 40px;">
                        <i class="bi bi-person text-secondary fs-5"></i>
                    </div>
                    <div class="min-w-0 flex-grow-1">
                        <div class="fw-bold text-dark small text-truncate">@AuthState.CurrentUser.FullName</div>
                        <div class="text-muted small text-truncate">@AuthState.CurrentUser.Email</div>
                    </div>
                    <span class="badge bg-secondary ms-2">@AuthState.CurrentUser.Role</span>
                </div>
                <a href="/logout" class="btn btn-outline-secondary w-100 d-flex align-items-center justify-content-center small py-1 shadow-sm">
                    <i class="bi bi-box-arrow-right me-2"></i> Sign out
                </a>
            </div>
        </aside>

        <!-- Main Content Area -->
        <div class="portal-main">
            <main class="flex-grow-1">
                @Body
            </main>
            <footer class="bg-white border-top py-4 px-5 mt-auto d-flex justify-content-between text-muted small">
                <span>Community Event Management System &copy; @DateTime.Now.Year</span>
                <span>Advanced Programming Assignment</span>
            </footer>
        </div>
    </div>
}
else
{
    <!-- Unauthenticated Landing Layout -->
    <div class="d-flex flex-column min-vh-100 bg-light">
        <nav class="landing-navbar bg-white border-bottom py-3 shadow-sm">
            <div class="container d-flex justify-content-between align-items-center">
                <a class="fw-bold text-dark fs-5 text-decoration-none d-flex align-items-center" href="/">
                    <i class="bi bi-layers-fill text-primary fs-4 me-2"></i> Community Events
                </a>
                <div class="d-flex align-items-center gap-3">
                    <a href="/events" class="text-decoration-none text-secondary fw-semibold small">Browse Events</a>
                    <a href="/login" class="btn btn-outline-secondary small py-2 px-4 fw-bold shadow-sm">Sign in</a>
                    <a href="/register" class="btn btn-primary small py-2 px-4 fw-bold shadow-sm">Get started</a>
                </div>
            </div>
        </nav>
        <main class="flex-grow-1">
            @Body
        </main>
        <footer class="bg-white border-top py-4 mt-auto">
            <div class="container text-center text-muted small">
                Community Event Management System &copy; @DateTime.Now.Year
            </div>
        </footer>
    </div>
}

@code {
    protected override void OnInitialized()
    {
        AuthState.OnAuthStateChanged += StateHasChanged;
    }

    public void Dispose()
    {
        AuthState.OnAuthStateChanged -= StateHasChanged;
    }
}